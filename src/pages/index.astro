---
// src/pages/index.astro
import { readFileSync, readdirSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import AudioEmbed from '../components/AudioEmbed.astro';
import DedicationCard from '../components/DedicationCard.astro';
import DedicationPlus from '../components/DedicationPlus.astro';
import VideoEmbed from '../components/VideoEmbed.astro';

const dataDir = join(process.cwd(), 'data', 'dedications');

// Carica tutte le dediche pubblicate ordinate per data
let all: any[] = [];
if (existsSync(dataDir)) {
  const files = readdirSync(dataDir).filter(f => f.endsWith('.json')).sort();
  all = files.map(f => JSON.parse(readFileSync(join(dataDir, f), 'utf-8')));
}

const today = new Date().toLocaleDateString('sv-SE', { timeZone: 'Europe/Rome' });

// La dedica piÃ¹ recente con date <= oggi e status published/scheduled
const published = all
  .filter(d => d.status === 'published' && d.date <= today)
  .sort((a, b) => {
    const byDate = b.date.localeCompare(a.date);
    if (byDate !== 0) return byDate;
    const byOrder = String(a.daily_order ?? '').localeCompare(String(b.daily_order ?? ''));
    if (byOrder !== 0) return byOrder;
    return String(a.id ?? '').localeCompare(String(b.id ?? ''));
  });

const dedication = published[0] ?? null;

// Ultime 4 dediche (esclusa quella in hero)
const recent = published.slice(1, 5);

const base = (import.meta.env.BASE_URL ?? '/').replace(/([^/])$/, '$1/');
const whatsappUrl = 'https://wa.me/393346296520';

function fmtDate(dateStr: string, dayName?: string) {
  const [y, m, d] = dateStr.split('-');
  const months = ['gennaio','febbraio','marzo','aprile','maggio','giugno','luglio','agosto','settembre','ottobre','novembre','dicembre'];
  const label = `${parseInt(d)} ${months[parseInt(m)-1]} ${y}`;
  return dayName ? `${dayName}, ${label}` : label;
}
---

<BaseLayout
  title="DDGPilliSite â€” Dediche Musicali"
  description="Una nuova dedica musicale ogni giorno. Ascolta, senti, condividi."
  ogTitle="DDGPilliSite â€” Dediche Musicali"
  ogDescription="Una nuova dedica musicale ogni giorno. Ascolta, senti, condividi."
  ogImage="/images/og-default.png"
  enableBackgroundMusic={true}
>

  <!-- â•â•â• HERO â•â•â• -->
  <section class="hero">
    <div class="hero-bg"></div>
    <!-- Ambient orbs -->
    <div class="hero-orb" style="width:500px;height:500px;top:-100px;left:-150px;background:radial-gradient(circle,rgba(124,58,237,0.35) 0%,transparent 70%)"></div>
    <div class="hero-orb" style="width:400px;height:400px;bottom:-80px;right:-100px;background:radial-gradient(circle,rgba(236,72,153,0.25) 0%,transparent 70%)"></div>

    <div class="container hero-content">
      <!-- Immagine -->
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;" class="anim-1">
        {dedication?.image?.path ? (
          <>
          <div class="hero-image-frame" id="hero-image-frame">
            <img
              src={base + (dedication.image.path).replace(/^\//, '')}
              alt={dedication.image.alt ?? ''}
              class="hero-image"
              width="420"
              height="525"
              loading="eager"
            />
          </div>
          <DedicationPlus dedication={dedication} mode="reactions" />
          </>
        ) : (
          <div class="img-placeholder">&#9834;</div>
        )}
      </div>

      <!-- Testo -->
      <div>
        {dedication ? (
          <>
            <div class="hero-date anim-1">
              {fmtDate(dedication.date, dedication.day_name)}
            </div>
            <h1 class="hero-song anim-2">{dedication.song_title}</h1>
            <p class="hero-artist anim-2">{dedication.artist}</p>
            <p class="hero-ded-label anim-3">{dedication.dedication_title}</p>

            <p class="hero-text anim-3">{dedication.dedication_text}</p>

            <div class="hero-actions anim-4">
              <a
                href={dedication.audio?.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-lg"
              >
                â–¶ Ascolta
              </a>
              <a
                href={dedication.vote?.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary btn-lg"
                data-site-config-target="googleVote"
              >
                â­ Votami
              </a>
              <DedicationPlus dedication={dedication} mode="button" />
              <a href={`${base}dediche/${dedication.id}/`} class="btn btn-secondary btn-lg">
                Leggi tutto â†’
              </a>
              <a href={`${base}link-utili/`} class="btn btn-secondary btn-lg">
                Link utili
              </a>
            </div>

            <div class="hero-contact anim-4">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-whatsapp btn-lg"
                aria-label="Contattami su WhatsApp"
              >
                <svg class="btn-icon" viewBox="0 0 32 32" aria-hidden="true">
                  <path fill="currentColor" d="M16 3C9.1 3 3.5 8.6 3.5 15.5c0 2.4.7 4.7 2 6.7L4 29l7-1.8c1.6.9 3.3 1.3 5 1.3 6.9 0 12.5-5.6 12.5-12.5S22.9 3 16 3Zm0 23c-1.5 0-3-.4-4.3-1.2l-.4-.2-4.1 1.1 1.1-4-.3-.4c-1.1-1.6-1.7-3.5-1.7-5.5C6.3 10.4 10.7 6 16 6s9.7 4.4 9.7 9.7S21.3 26 16 26Zm5.5-7.2c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.2-.4-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.5-.6c.2-.2.2-.3.3-.5.1-.2.1-.4 0-.6-.1-.2-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.6s1.1 3 1.2 3.2c.2.2 2.2 3.4 5.3 4.7.7.3 1.3.5 1.8.6.8.2 1.4.2 2 .1.6-.1 1.8-.7 2-1.4.2-.7.2-1.3.2-1.4 0-.1-.2-.2-.5-.4Z"/>
                </svg>
                Contattami su WhatsApp
              </a>
            </div>

            {dedication.tags && dedication.tags.length > 0 && (
              <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:0.5rem;" class="anim-4">
                {dedication.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </>
        ) : (
          <div>
            <h1 class="hero-song anim-1" style="font-family:var(--font-serif)">Nessuna dedica oggi ðŸŽµ</h1>
            <p class="hero-text anim-2">Torna domani per la prossima dedica musicale!</p>
            <a href={`${base}archive/`} class="btn btn-primary btn-lg anim-3">Vedi archivio</a>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- â•â•â• AUDIO EMBED â•â•â• -->
  {dedication && (
    <section style="padding:2rem 0;background:var(--bg-surface);">
      <div class="container-narrow reveal">
        <AudioEmbed url={dedication.audio.url} type={dedication.audio.type} />
      </div>
    </section>
  )}

  {dedication?.video && (
    <section style="padding:2rem 0 3rem;background:var(--bg-surface);">
      <div class="container-narrow reveal">
        <VideoEmbed
          type={dedication.video.type}
          url={dedication.video.url}
          poster={dedication.video.poster}
          title={dedication.video.title || 'Video della dedica'}
          description={dedication.video.description}
        />
      </div>
    </section>
  )}

  <!-- â•â•â• RECENT DEDICHE â•â•â• -->
  {recent.length > 0 && (
    <section style="padding:5rem 0;">
      <div class="container">
        <div style="text-align:center;margin-bottom:3rem;" class="reveal">
          <span class="section-label">Archivio</span>
          <h2 class="section-title">Dediche recenti</h2>
          <div class="divider"></div>
        </div>
        <div class="archive-grid reveal">
          {recent.map((d: any) => (
            <DedicationCard
              id={d.id}
              date={d.date}
              day_name={d.day_name}
              song_title={d.song_title}
              artist={d.artist}
              image={d.image}
              tags={d.tags}
              dedication_text={d.dedication_text}
              short_phrase={d.short_phrase}
            />
          ))}
        </div>
        <div style="text-align:center;margin-top:3rem;" class="reveal">
          <a href={`${base}archive/`} class="btn btn-secondary">
            Vedi tutto l'archivio â†’
          </a>
        </div>
      </div>
    </section>
  )}

</BaseLayout>
