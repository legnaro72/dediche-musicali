---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import '../styles/landscape-pan.css';
import GlobalSiteEffect from '../components/GlobalSiteEffect.astro';
import UserIdentityModal from '../components/UserIdentityModal.astro';
import { ViewTransitions } from 'astro:transitions';
export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalUrl?: string;
  enableBackgroundMusic?: boolean;
}

const {
  title,
  description = 'Dediche musicali giornaliere - ascolta, senti, condividi.',
  ogTitle,
  ogDescription,
  ogImage,
  canonicalUrl,
  enableBackgroundMusic = true,
} = Astro.props;

const base = (import.meta.env.BASE_URL ?? '/').replace(/([^/])$/, '$1/');
const feedbackApiUrl = import.meta.env.PUBLIC_DDGPILLI_FEEDBACK_API_URL ?? (import.meta.env.DEV ? 'http://127.0.0.1:8787' : '');
const siteConfigUrl = import.meta.env.PUBLIC_DDGPILLI_SITE_CONFIG_URL
  ?? (import.meta.env.DEV
    ? `${base}config/site-settings.json`
    : 'https://raw.githubusercontent.com/legnaro72/dediche-musicali/main/public/config/site-settings.json');
const siteUrl = import.meta.env.SITE ?? 'https://example.github.io';
const fullCanonical = canonicalUrl ?? (siteUrl + Astro.url.pathname);
const fullOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : siteUrl + base + ogImage.replace(/^\//, ''))
  : siteUrl + base + 'images/og-default.png';
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#08070f" />
  <meta name="color-scheme" content="dark" />
  <meta name="application-name" content="DDGPilliSite" />
  <meta name="ddgpilli-base" content={base} />
  <meta name="ddgpilli-feedback-api" content={feedbackApiUrl} />
  <meta name="ddgpilli-site-config-url" content={siteConfigUrl} />

  <!-- PWA / mobile app -->
  <link rel="manifest" href={`${base}manifest.json`} />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="DDGPilli" />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}icons/apple-touch-icon.png`} />
  <link rel="apple-touch-startup-image" href={`${base}icons/apple-splash-2048.png`} />

  <!-- Primary -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- OpenGraph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:image"       content={fullOgImage} />
  <meta property="og:url"         content={fullCanonical} />
  <meta property="og:locale"      content="it_IT" />

  <!-- Twitter card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image"       content={fullOgImage} />

  <!-- Robots -->
  <meta name="robots" content="index, follow" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}favicon/favicon.svg`} />
  <link rel="icon" type="image/png" sizes="192x192" href={`${base}icons/icon-192.png`} />
  <ViewTransitions />

  <!-- Preconnect Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <GlobalSiteEffect />

  <section class="site-lock" data-site-lock hidden aria-live="polite">
    <div class="site-lock-shell" data-site-lock-phase="initial">
      <div class="site-lock-panel" data-site-lock-initial>
        <h1 data-site-lock-title>ERROR 404</h1>
        <p class="site-lock-message" data-site-lock-message>Il server non e' al momento raggiungibile.</p>
        <button class="site-lock-button" type="button" data-site-lock-action>Verifica stato sistema</button>
        <div class="site-lock-progress" aria-hidden="true"><span></span></div>
      </div>

      <div class="site-lock-panel site-lock-second" hidden data-site-lock-second>
        <img data-site-lock-image src="" alt="" hidden />
        <p class="site-lock-message" data-site-lock-image-message>Sistema momentaneamente offline.</p>
        <p class="site-lock-admin" data-site-lock-admin-message>
          Per il ripristino del servizio contattare l'amministratore del sito.
        </p>
      </div>
    </div>
  </section>

  <!-- Navbar -->
  <nav class="navbar" id="navbar">
    <div class="container navbar-inner">
      <a class="navbar-brand" href={base}>&#9834; DDGPilli</a>
      
      <button
        class="navbar-menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-navigation"
        data-nav-toggle
      >
        Menu
      </button>

      {enableBackgroundMusic && (
        <div class="ambient-audio" data-background-music-control transition:persist>
          <button
            class="ambient-audio-toggle"
            type="button"
            aria-pressed="true"
            aria-label="Disattiva musica di sottofondo"
          >
            <span class="ambient-audio-icon" aria-hidden="true">&#9834;</span>
          </button>
          <p class="ambient-audio-hint" data-background-music-hint hidden>
            Tocca per attivare la musica
          </p>
        </div>
      )}

      <UserIdentityModal />

      <ul class="navbar-nav" id="primary-navigation">
        <li><a href={base}>Home</a></li>
        <li><a href={`${base}archive/`}>Archivio</a></li>
        <li><a href={`${base}statistiche/`}>Statistiche</a></li>
        <li><a href={`${base}link-utili/`}>Link utili</a></li>
      </ul>
    </div>
  </nav>

  <!-- Main content -->
  <main>
    <slot />
  </main>

  <div class="app-install" data-app-install hidden>
    <div class="app-install-copy">
      <strong>DDGPilli come app</strong>
      <span data-app-install-text>Installa sulla Home per aprirla a schermo intero.</span>
    </div>
    <div class="app-install-actions">
      <button class="app-install-btn" type="button" data-app-install-btn>Installa</button>
      <button class="app-install-close" type="button" aria-label="Nascondi invito installazione" data-app-install-close>&times;</button>
    </div>
  </div>

  <div class="app-install-modal" data-app-install-modal hidden>
    <div class="app-install-dialog" role="dialog" aria-modal="true" aria-labelledby="install-title">
      <button class="app-install-dialog-close" type="button" aria-label="Chiudi" data-app-install-modal-close>&times;</button>
      <h2 id="install-title">Aggiungi alla Home</h2>
      <p data-app-install-modal-text>
        Apri il menu del browser e scegli "Aggiungi a schermata Home".
      </p>
    </div>
  </div>

  {enableBackgroundMusic && (
    <>
      <div class="app-intro" data-audio-intro hidden>
        <div class="app-intro-panel">
          <p class="app-intro-kicker">DDGPilli</p>
          <h2>Dedica del giorno</h2>
          <p class="app-intro-text">Tocca Entra per avviare l'esperienza con musica di sottofondo.</p>
          <div class="app-intro-progress" aria-hidden="true">
            <span data-audio-intro-progress></span>
          </div>
          <p class="app-intro-status" data-audio-intro-status>Audio pronto</p>
          <div class="app-intro-actions">
            <button class="app-intro-start" type="button" data-audio-intro-start>Entra</button>
            <button class="app-intro-skip" type="button" data-audio-intro-skip>Continua senza audio</button>
          </div>
        </div>
      </div>
    </>
  )}

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <p>
        &#9834; <strong>DDGPilliSite</strong> - Dediche musicali giornaliere
        &nbsp;&middot;&nbsp;
        <a href={`${base}archive/`}>Archivio</a>
        &nbsp;&middot;&nbsp;
        <a href={`${base}statistiche/`}>Statistiche</a>
        &nbsp;&middot;&nbsp;
        <button data-uid-edit class="uid-footer-edit-btn" aria-label="Modifica nome e cognome">&#9999;&#65039;</button>
      </p>
      <p style="margin-top:0.5rem; font-size:0.75rem; opacity:0.5;">
        Pubblicato su GitHub Pages &middot; Gratuito, open source, fatto con amore &#9834;
      </p>
    </div>
  </footer>

  <!-- Navbar scroll effect + reveal animation -->
  <script is:inline>
    const appBase = document.querySelector('meta[name="ddgpilli-base"]')?.getAttribute('content') ?? '/';
    window.__DDGPILLI_BASE = appBase;

    const configuredSiteConfigUrl = document.querySelector('meta[name="ddgpilli-site-config-url"]')?.getAttribute('content')?.trim() || '';
    const isLocalPreview = ['localhost', '127.0.0.1', '::1'].includes(window.location.hostname);
    const siteConfigUrl = isLocalPreview ? `${appBase}config/site-settings.json` : configuredSiteConfigUrl;
    const resolveSiteAsset = (path) => {
      if (!path) return '';
      if (/^https?:\/\//i.test(path)) return path;
      return `${appBase}${String(path).replace(/^\//, '')}`;
    };

    const setText = (selector, value) => {
      const element = document.querySelector(selector);
      if (element) element.textContent = value || '';
    };

    const applyFeedbackApiUrl = (settings) => {
      const configuredUrl = String(settings?.feedbackApiUrl || settings?.feedback?.apiUrl || '').trim();
      if (!configuredUrl) return;
      const meta = document.querySelector('meta[name="ddgpilli-feedback-api"]');
      if (meta) meta.setAttribute('content', configuredUrl);
      window.__DDGPILLI_FEEDBACK_API_URL = configuredUrl;
    };

    const applyFakeErrorMode = (fakeError) => {
      const lock = document.querySelector('[data-site-lock]');
      if (!(lock instanceof HTMLElement)) return;

      const enabledValue = fakeError?.enabled;
      const enabled = enabledValue === true || enabledValue === 1 || String(enabledValue).toLowerCase() === 'true' || String(enabledValue).toLowerCase() === 'on';
      lock.hidden = !enabled;
      document.body.classList.toggle('site-is-locked', enabled);
      if (!enabled) {
        const initial = document.querySelector('[data-site-lock-initial]');
        const second = document.querySelector('[data-site-lock-second]');
        const shell = document.querySelector('[data-site-lock-phase]');
        if (initial instanceof HTMLElement) initial.hidden = false;
        if (second instanceof HTMLElement) second.hidden = true;
        if (shell instanceof HTMLElement) shell.setAttribute('data-site-lock-phase', 'initial');
        return;
      }

      setText('[data-site-lock-title]', fakeError.title || 'ERROR 404');
      setText('[data-site-lock-message]', fakeError.message || "Il server non e' al momento raggiungibile.");
      setText('[data-site-lock-action]', fakeError.buttonText || 'Verifica stato sistema');
      setText('[data-site-lock-image-message]', fakeError.imageMessage || 'Sistema momentaneamente offline.');
      setText('[data-site-lock-admin-message]', fakeError.adminMessage || "Per il ripristino del servizio contattare l'amministratore del sito.");

      const image = document.querySelector('[data-site-lock-image]');
      const imageUrl = resolveSiteAsset(fakeError.imagePath || '');
      if (image instanceof HTMLImageElement && imageUrl) {
        image.src = imageUrl;
        image.hidden = false;
      } else if (image instanceof HTMLImageElement) {
        image.removeAttribute('src');
        image.hidden = true;
      }
    };

    const applyGlobalSiteEffectFallback = (settings) => {
      const root = document.getElementById('global-site-effect');
      if (!(root instanceof HTMLElement)) return;
      const validEffects = new Set([
        'sparkles',
        'snow',
        'hearts',
        'hearts_red_blue',
        'music_notes',
        'glow_bubbles',
        'petals',
        'confetti',
        'balloons',
        'stars',
        'shooting_stars',
        'concert_lights',
        'soft_flashes',
        'fireworks',
        'diamond_pilli',
        'diamond_pip',
        'soccer_balls',
        'smiling_suns',
        'glitter_butterflies',
      ]);
      const validIntensities = new Set(['low', 'medium', 'high']);
      const rawEffect = String(settings?.siteEffect || 'none').trim();
      const effect = rawEffect === 'diamond_pip' ? 'diamond_pilli' : rawEffect;
      if (!validEffects.has(effect)) {
        delete root.dataset.effect;
        delete root.dataset.intensity;
        delete root.dataset.backdrop;
        return;
      }
      const intensity = String(settings?.effectIntensity || 'medium').trim();
      const backdropValue = settings?.effectBackdrop;
      const backdrop = backdropValue === true
        || backdropValue === 1
        || ['true', '1', 'on', 'yes'].includes(String(backdropValue || '').trim().toLowerCase());
      root.dataset.effect = effect;
      root.dataset.intensity = validIntensities.has(intensity) ? intensity : 'medium';
      root.dataset.backdrop = backdrop ? 'on' : 'off';
    };

    const applySiteSettings = (settings) => {
      window.__DDGPILLI_SITE_SETTINGS = settings || {};
      applyFeedbackApiUrl(settings);
      const buttons = settings?.buttons || {};
      const visibility = {
        googleVote: buttons.googleVote !== false,
        plusVote: buttons.plusVote !== false,
      };

      for (const [key, isVisible] of Object.entries(visibility)) {
        document.querySelectorAll(`[data-site-config-target="${key}"]`).forEach((element) => {
          if (element instanceof HTMLElement) element.hidden = !isVisible;
        });
      }

      applyFakeErrorMode(settings?.fakeError || {});
      applyGlobalSiteEffectFallback(settings || {});
      window.__DDGPILLI_APPLY_GLOBAL_SITE_EFFECT?.(settings || {});
      window.dispatchEvent(new CustomEvent('ddgpilli:site-settings-updated', { detail: settings || {} }));
    };

    const loadSiteSettings = async () => {
      if (!siteConfigUrl) return;
      try {
        const separator = siteConfigUrl.includes('?') ? '&' : '?';
        const response = await fetch(`${siteConfigUrl}${separator}t=${Date.now()}`, { cache: 'no-store' });
        if (!response.ok) return;
        applySiteSettings(await response.json());
      } catch (error) {
        console.warn('Configurazione sito non caricata:', error);
      }
    };

    if (!window.__DDGPILLI_SITE_CONFIG_READY) {
      window.__DDGPILLI_SITE_CONFIG_READY = true;
      loadSiteSettings();
      window.setInterval(loadSiteSettings, 15000);
      window.addEventListener('focus', loadSiteSettings);
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') loadSiteSettings();
      });
      document.addEventListener('astro:page-load', loadSiteSettings);
    }

    const feedbackApiUrl = () => (
      document.querySelector('meta[name="ddgpilli-feedback-api"]')?.getAttribute('content')?.trim()
      || window.__DDGPILLI_FEEDBACK_API_URL
      || ''
    );

    const normalizeUserKey = (value) => String(value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim()
      .toLowerCase()
      .replace(/\s+/g, ' ')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 160);

    const currentVisitPage = () => {
      const path = window.location.pathname || '/';
      const basePath = appBase === '/' ? '' : appBase.replace(/\/$/, '');
      return basePath && path.startsWith(basePath) ? path.slice(basePath.length) || '/' : path;
    };

    const trackSiteVisit = async () => {
      if (window.__DDGPILLI_VISIT_TRACKED_FOR_PAGE === window.location.pathname) return;
      const apiUrl = feedbackApiUrl();
      if (!apiUrl || !window.__DDGPILLI?.hasIdentity?.()) return;

      const identity = window.__DDGPILLI.getUserIdentity?.() || {};
      const userName = [identity.nome, identity.cognome].filter(Boolean).join(' ').trim() || identity.displayName || '';
      const userKey = normalizeUserKey([identity.nome, identity.cognome].filter(Boolean).join(' ') || userName);
      if (!userKey || !userName) return;

      window.__DDGPILLI_VISIT_TRACKED_FOR_PAGE = window.location.pathname;
      try {
        const response = await fetch(`${apiUrl.replace(/\/$/, '')}/track_visit`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            userKey,
            userName,
            page: currentVisitPage(),
          }),
          keepalive: true,
        });
        if (!response.ok) window.__DDGPILLI_VISIT_TRACKED_FOR_PAGE = '';
      } catch (error) {
        window.__DDGPILLI_VISIT_TRACKED_FOR_PAGE = '';
        console.warn('Tracciamento visita non salvato:', error);
      }
    };

    if (!window.__DDGPILLI_VISIT_TRACKING_READY) {
      window.__DDGPILLI_VISIT_TRACKING_READY = true;
      window.addEventListener('load', trackSiteVisit, { once: true });
      window.addEventListener('ddgpilli:identity-saved', trackSiteVisit);
      window.addEventListener('ddgpilli:site-settings-updated', trackSiteVisit);
      document.addEventListener('astro:page-load', () => {
        window.__DDGPILLI_VISIT_TRACKED_FOR_PAGE = '';
        trackSiteVisit();
      });
    }

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest('[data-site-lock-action]')) return;
      const initial = document.querySelector('[data-site-lock-initial]');
      const second = document.querySelector('[data-site-lock-second]');
      if (initial instanceof HTMLElement) initial.hidden = true;
      if (second instanceof HTMLElement) second.hidden = false;
      const panel = target.closest('[data-site-lock-phase]');
      if (panel instanceof HTMLElement) panel.setAttribute('data-site-lock-phase', 'second');
    });

    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.getRegistrations?.().then((registrations) => {
          registrations.forEach((registration) => {
            if (registration.scope.includes('/dediche-musicali/')) registration.unregister();
          });
        }).catch(() => {});
      }, { once: true });
    }

    const setMobileMenuOpen = (isOpen) => {
      const navToggle = document.querySelector('[data-nav-toggle]');
      const navMenu = document.getElementById('primary-navigation');
      navMenu?.classList.toggle('is-open', isOpen);
      navToggle?.setAttribute('aria-expanded', String(isOpen));
    };

    if (!window.__DDGPILLI_NAV_READY) {
      window.__DDGPILLI_NAV_READY = true;
      const toggleMobileMenu = (event) => {
        event.preventDefault();
        event.stopPropagation();
        const navMenu = document.getElementById('primary-navigation');
        setMobileMenuOpen(!navMenu?.classList.contains('is-open'));
      };

      document.querySelectorAll('[data-nav-toggle]').forEach((toggle) => {
        toggle.addEventListener('click', toggleMobileMenu);
        toggle.addEventListener('touchend', toggleMobileMenu, { passive: false });
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (target.closest('[data-nav-toggle]')) {
          toggleMobileMenu(event);
          return;
        }

        if (target.closest('#primary-navigation a')) {
          setMobileMenuOpen(false);
          return;
        }

        if (!target.closest('#primary-navigation') && !target.closest('[data-nav-toggle]')) {
          setMobileMenuOpen(false);
        }
      });

      document.addEventListener('astro:before-swap', () => setMobileMenuOpen(false));
      window.addEventListener('resize', () => {
        if (window.matchMedia('(min-width: 769px)').matches) setMobileMenuOpen(false);
      }, { passive: true });
    }

    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) navbar?.classList.add('scrolled');
      else navbar?.classList.remove('scrolled');
    }, { passive: true });

    // Scroll reveal
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.1 }
    );
    reveals.forEach(el => observer.observe(el));
  </script>

  <!-- Landscape pan detection -->
  <script>
    function initLandscapePan() {
      const imgs = document.querySelectorAll('.hero-image-frame img, .image-frame img');
      imgs.forEach((el) => {
        const applyLandscape = () => {
          const frame = el.closest('.hero-image-frame') || el.closest('.image-frame');
          if (!frame) return;

          // Usiamo requestAnimationFrame per essere sicuri che il layout sia pronto
          requestAnimationFrame(() => {
            const fw = frame.getBoundingClientRect().width;
            if (fw > 0) {
              frame.style.setProperty('--frame-w', fw + 'px');
              const isWide = el.naturalWidth > el.naturalHeight * 1.15;
              frame.classList.toggle('landscape-frame', isWide);
              frame.classList.toggle('portrait-frame', !isWide);
            }
          });
        };

        if (el.complete && el.naturalWidth > 0) {
          applyLandscape();
        } else {
          el.addEventListener('load', applyLandscape, { once: true });
        }
      });
    }

    // Esegui al caricamento e sui cambiamenti di dimensione
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLandscapePan);
    } else {
      initLandscapePan();
    }

    window.addEventListener('resize', () => {
      document.querySelectorAll('.landscape-frame').forEach((frame) => {
        requestAnimationFrame(() => {
          frame.style.setProperty('--frame-w', frame.getBoundingClientRect().width + 'px');
        });
      });
    }, { passive: true });
  </script>

  <script>
    (() => {
      const root = document.querySelector('[data-app-install]');
      const installButton = document.querySelector('[data-app-install-btn]');
      const closeButton = document.querySelector('[data-app-install-close]');
      const installText = document.querySelector('[data-app-install-text]');
      const modal = document.querySelector('[data-app-install-modal]');
      const modalText = document.querySelector('[data-app-install-modal-text]');
      const modalClose = document.querySelector('[data-app-install-modal-close]');
      if (!(root instanceof HTMLElement) || !(installButton instanceof HTMLButtonElement)) return;

      const dismissedUntilKey = 'ddgpilli-install-dismissed-until';
      const installedKey = 'ddgpilli-pwa-installed';
      const isAppDisplayMode =
        window.matchMedia('(display-mode: fullscreen)').matches ||
        window.matchMedia('(display-mode: standalone)').matches ||
        window.navigator.standalone === true;
      const isIos = /iphone|ipad|ipod/i.test(window.navigator.userAgent);
      let deferredPrompt = null;

      if (isAppDisplayMode) {
        localStorage.setItem(installedKey, 'true');
      }

      const show = () => {
        const dismissedUntil = Number(localStorage.getItem(dismissedUntilKey) || 0);
        const alreadyInstalled = localStorage.getItem(installedKey) === 'true';
        if (isAppDisplayMode || alreadyInstalled || dismissedUntil > Date.now()) return;
        root.hidden = false;
      };

      const openGuide = (message: string) => {
        if (modalText) modalText.textContent = message;
        if (modal instanceof HTMLElement) modal.hidden = false;
      };

      if (isIos) {
        installButton.textContent = 'Come fare';
        if (installText) installText.textContent = 'Su iPhone si aggiunge dal pulsante Condividi di Safari.';
        setTimeout(show, 1200);
      } else {
        setTimeout(() => {
          if (!deferredPrompt && installText) {
            installText.textContent = 'Se il prompt non appare, usa il menu del browser per installarla.';
          }
          show();
        }, 1800);
      }

      window.addEventListener('beforeinstallprompt', (event) => {
        event.preventDefault();
        deferredPrompt = event;
        installButton.textContent = 'Installa';
        if (installText) installText.textContent = 'Aggiungila alla Home e aprila senza barra browser.';
        show();
      });

      window.addEventListener('appinstalled', () => {
        root.hidden = true;
        localStorage.setItem(installedKey, 'true');
        localStorage.removeItem(dismissedUntilKey);
      });

      installButton.addEventListener('click', async () => {
        if (deferredPrompt) {
          deferredPrompt.prompt();
          await deferredPrompt.userChoice.catch(() => null);
          deferredPrompt = null;
          root.hidden = true;
          return;
        }

        if (isIos) {
          openGuide('Su iPhone: apri Safari, tocca Condividi, poi scegli "Aggiungi a schermata Home". Dopo il salvataggio si apre come app standalone.');
          return;
        }

        openGuide('Se il browser non mostra il prompt automatico, apri il menu del browser e scegli "Installa app" oppure "Aggiungi alla schermata Home".');
      });

      closeButton?.addEventListener('click', () => {
        root.hidden = true;
        localStorage.setItem(dismissedUntilKey, String(Date.now() + 6 * 60 * 60 * 1000));
      });

      modalClose?.addEventListener('click', () => {
        if (modal instanceof HTMLElement) modal.hidden = true;
      });

      modal?.addEventListener('click', (event) => {
        if (event.target === modal && modal instanceof HTMLElement) modal.hidden = true;
      });
    })();
  </script>

  {enableBackgroundMusic && (
    <script>
      (() => {
        const appBase = document.querySelector('meta[name="ddgpilli-base"]')?.getAttribute('content') ?? '/';
        const root = document.querySelector('[data-background-music-control]');
        const button = root?.querySelector('.ambient-audio-toggle');
        const hint = root?.querySelector('[data-background-music-hint]');
        const intro = document.querySelector('[data-audio-intro]');
        const introStart = document.querySelector('[data-audio-intro-start]');
        const introSkip = document.querySelector('[data-audio-intro-skip]');
        const introProgress = document.querySelector('[data-audio-intro-progress]');
        const introStatus = document.querySelector('[data-audio-intro-status]');
        if (!(root instanceof HTMLElement) || !(button instanceof HTMLButtonElement)) return;

        const storageKey = 'ddgpilli-background-audio-enabled';
        const timeKey = 'ddgpilli-background-audio-current-time';
        const introKey = 'ddgpilli-audio-intro-seen';
        let audio;
        let progressTimer;
        let config = {
          backgroundMusic: `${appBase}background-music/main-converted.mp3`,
          audioDefaultEnabled: true,
          audioVolume: 0.3,
        };
        let enabled = true;
        let waitingForGesture = false;
        let unlockRegistered = false;
        let isPlaying = false;

        const trackAudioEvent = (eventName) => {
          if (typeof window.gtag === 'function') window.gtag('event', eventName, { event_category: 'pwa_audio' });
          if (typeof window.fbq === 'function') window.fbq('trackCustom', eventName);
        };

        const applyUi = (isWaiting = false) => {
          waitingForGesture = isWaiting;
          button.setAttribute('aria-pressed', String(isPlaying));
          button.setAttribute('aria-label', isPlaying ? 'Disattiva musica di sottofondo' : 'Attiva musica di sottofondo');
          root.classList.toggle('is-off', !isPlaying);
          root.classList.toggle('is-waiting', isWaiting && enabled);
          if (hint) hint.hidden = !(isWaiting && enabled);
        };

        const setIntroProgress = (value, label) => {
          if (introProgress instanceof HTMLElement) introProgress.style.width = `${Math.max(0, Math.min(100, value))}%`;
          if (introStatus && label) introStatus.textContent = label;
        };

        const requestAppFullscreen = async () => {
          if (document.fullscreenElement) return;
          if (window.matchMedia('(display-mode: fullscreen)').matches) return;
          if (window.navigator.standalone === true) return;

          try {
            await document.documentElement.requestFullscreen?.({ navigationUI: 'hide' });
          } catch {
            // Desktop browsers allow fullscreen only in some user-gesture contexts.
          }
        };

        const hideIntro = () => {
          if (intro instanceof HTMLElement) intro.hidden = true;
          if (progressTimer) window.clearInterval(progressTimer);
          sessionStorage.setItem(introKey, 'true');
        };

        const showIntro = () => {
          if (intro instanceof HTMLElement) intro.hidden = false;
          setIntroProgress(0, 'Audio pronto');
        };

        const updateBufferedProgress = () => {
          const current = ensureAudio();
          if (current.duration && Number.isFinite(current.duration) && current.buffered.length > 0) {
            const bufferedEnd = current.buffered.end(current.buffered.length - 1);
            setIntroProgress(Math.min(95, (bufferedEnd / current.duration) * 100), 'Caricamento musica...');
          }
        };

        const startSoftProgress = () => {
          if (progressTimer) window.clearInterval(progressTimer);
          let value = 8;
          setIntroProgress(value, 'Caricamento musica...');
          progressTimer = window.setInterval(() => {
            value = Math.min(82, value + 4);
            setIntroProgress(value, 'Caricamento musica...');
          }, 180);
        };

        const audioErrorLabel = (current) => {
          const code = current?.error?.code;
          if (code === 1) return 'Riproduzione audio interrotta.';
          if (code === 2) return 'Errore di rete durante il caricamento audio.';
          if (code === 3) return 'Il file audio non puo essere decodificato.';
          if (code === 4) return 'Formato audio non supportato dal browser.';
          return 'Audio non avviato. Tocca Audio per riprovare.';
        };

        const ensureAudio = () => {
          if (audio) return audio;
          audio = new Audio(config.backgroundMusic);
          audio.loop = true;
          audio.preload = 'auto';
          audio.volume = Math.max(0, Math.min(1, Number(config.audioVolume) || 0.3));
          audio.muted = false;
          audio.playsInline = true;
          audio.addEventListener('loadedmetadata', () => {
            const savedTime = Number(localStorage.getItem(timeKey) || 0);
            if (Number.isFinite(savedTime) && savedTime > 0 && audio.duration && savedTime < audio.duration) {
              audio.currentTime = savedTime;
            }
          }, { once: true });
          audio.load();
          audio.addEventListener('progress', updateBufferedProgress);
          audio.addEventListener('canplay', () => setIntroProgress(92, 'Quasi pronto...'));
          audio.addEventListener('playing', () => {
            isPlaying = true;
            applyUi(false);
            setIntroProgress(100, 'Musica avviata');
            window.setTimeout(hideIntro, 250);
          });
          audio.addEventListener('pause', () => {
            isPlaying = false;
            applyUi(false);
          });
          audio.addEventListener('error', () => {
            setIntroProgress(0, audioErrorLabel(audio));
            applyUi(true);
          });
          return audio;
        };

        const waitForPlayback = (current) => new Promise((resolve, reject) => {
          if (!current.paused && current.readyState >= 2) {
            resolve(true);
            return;
          }

          const timeout = window.setTimeout(() => {
            cleanup();
            reject(new Error('Audio playback timeout'));
          }, 6500);

          const onPlaying = () => {
            cleanup();
            resolve(true);
          };

          const onError = () => {
            cleanup();
            reject(current.error || new Error('Audio playback error'));
          };

          function cleanup() {
            window.clearTimeout(timeout);
            current.removeEventListener('playing', onPlaying);
            current.removeEventListener('error', onError);
          }

          current.addEventListener('playing', onPlaying, { once: true });
          current.addEventListener('error', onError, { once: true });
        });

        const registerUnlock = () => {
          if (unlockRegistered) return;
          unlockRegistered = true;
          const unlock = () => {
            if (enabled) playAudio(true);
            window.removeEventListener('pointerdown', unlock);
            window.removeEventListener('keydown', unlock);
          };
          window.addEventListener('pointerdown', unlock, { once: true, passive: true });
          window.addEventListener('keydown', unlock, { once: true });
        };

        const playAudio = async (fromGesture = false) => {
          if (!enabled) return;
          const current = ensureAudio();
          try {
            if (fromGesture) startSoftProgress();
            const playResult = current.play();
            if (playResult && typeof playResult.catch === 'function') {
              playResult.catch((error) => {
                console.warn('Background audio play() rejected:', error);
                setIntroProgress(0, audioErrorLabel(current));
                applyUi(true);
              });
            }
            await waitForPlayback(current);
            isPlaying = true;
            applyUi(false);
            trackAudioEvent(fromGesture ? 'background_audio_unlocked' : 'background_audio_started');
          } catch (error) {
            if (progressTimer) window.clearInterval(progressTimer);
            console.warn('Background audio non avviato:', error);
            setIntroProgress(0, fromGesture ? audioErrorLabel(current) : 'Tocca Entra per autorizzare audio.');
            applyUi(true);
            registerUnlock();
          }
        };

        const stopAudio = () => {
          if (audio && Number.isFinite(audio.currentTime)) localStorage.setItem(timeKey, String(audio.currentTime));
          if (audio) audio.pause();
          isPlaying = false;
          enabled = false;
          localStorage.setItem(storageKey, 'false');
          applyUi(false);
          trackAudioEvent('background_audio_stopped');
        };

        const readPreference = () => {
          const saved = localStorage.getItem(storageKey);
          enabled = saved === null ? Boolean(config.audioDefaultEnabled) : saved === 'true';
        };

        const init = async () => {
          try {
            const response = await fetch(`${appBase}pwa-config.json?v=4`, { cache: 'no-store' });
            if (response.ok) config = { ...config, ...(await response.json()) };
          } catch {
            console.warn('Configurazione PWA non caricata, uso valori di default.');
          }

          readPreference();
          applyUi(false);
          if (enabled && sessionStorage.getItem(introKey) !== 'true') {
            showIntro();
            return;
          }
          if (enabled) window.requestIdleCallback ? requestIdleCallback(() => playAudio(false)) : setTimeout(() => playAudio(false), 250);
        };

        button.addEventListener('click', () => {
          if (isPlaying) {
            stopAudio();
            return;
          }

          enabled = true;
          localStorage.setItem(storageKey, 'true');
          if (waitingForGesture) {
            playAudio(true);
            return;
          }
          playAudio(true);
        });

        introStart?.addEventListener('click', () => {
          enabled = true;
          localStorage.setItem(storageKey, 'true');
          applyUi(false);
          requestAppFullscreen();
          playAudio(true);
        });

        introSkip?.addEventListener('click', () => {
          enabled = false;
          localStorage.setItem(storageKey, 'false');
          stopAudio();
          hideIntro();
        });

        window.addEventListener('pagehide', () => {
          if (audio && Number.isFinite(audio.currentTime)) localStorage.setItem(timeKey, String(audio.currentTime));
        });

        init();
      })();
    </script>
  )}
</body>
</html>
