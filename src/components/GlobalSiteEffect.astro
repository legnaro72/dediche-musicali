<div class="global-site-effect" id="global-site-effect" aria-hidden="true"></div>

<script>
  import { tsParticles } from '@tsparticles/engine';
  import { loadSlim } from '@tsparticles/slim';

  const effectRootId = 'global-site-effect';
  const validEffects = new Set([
    'auto',
    'none',
    'sparkles',
    'snow',
    'hearts',
    'hearts_red_blue',
    'music_notes',
    'glow_bubbles',
    'petals',
    'confetti',
    'balloons',
    'stars',
    'shooting_stars',
    'concert_lights',
    'soft_flashes',
    'fireworks',
    'diamond_pilli',
    'diamond_pip',
    'soccer_balls',
    'smiling_suns',
    'glitter_butterflies',
  ]);
  const customEffects = new Set(['diamond_pilli', 'hearts_red_blue', 'soccer_balls', 'smiling_suns', 'glitter_butterflies']);
  const validIntensities = new Set(['low', 'medium', 'high']);
  const intensityMap = {
    low: { count: 18, customCount: 16, speed: 0.55, rate: 0.65, glow: 0.72 },
    medium: { count: 34, customCount: 28, speed: 0.9, rate: 1, glow: 0.9 },
    high: { count: 58, customCount: 46, speed: 1.25, rate: 1.45, glow: 1.08 },
  };

  let engineReady = false;
  let activeContainer = null;
  let activeKey = '';

  const reducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const normalizeEffect = (value) => {
    const effect = String(value || 'none').trim();
    if (!validEffects.has(effect)) return 'none';
    if (effect === 'diamond_pip') return 'diamond_pilli';
    return effect === 'auto' ? 'none' : effect;
  };

  const normalizeIntensity = (value) => {
    const intensity = String(value || 'medium').trim();
    return validIntensities.has(intensity) ? intensity : 'medium';
  };

  const baseOptions = (effect, intensity) => ({
    key: `${effect}:${intensity}`,
    options: {
      fullScreen: { enable: false },
      detectRetina: true,
      fpsLimit: intensity === 'high' ? 50 : 42,
      background: { color: { value: 'transparent' } },
      interactivity: { events: { resize: true } },
      particles: {
        number: { value: intensityMap[intensity].count, density: { enable: true, width: 1100, height: 900 } },
        collisions: { enable: false },
        opacity: { value: { min: 0.25, max: 0.85 } },
        size: { value: { min: 2, max: 5 } },
        move: {
          enable: true,
          speed: intensityMap[intensity].speed,
          outModes: { default: 'out' },
        },
      },
    },
  });

  const buildOptions = (effect, intensity) => {
    const built = baseOptions(effect, intensity);
    const particles = built.options.particles;

    if (effect === 'snow') {
      particles.color = { value: ['#ffffff', '#dbeafe', '#bae6fd'] };
      particles.shape = { type: 'circle' };
      particles.number.value = Math.round(intensityMap[intensity].count * 1.25);
      particles.opacity = { value: { min: 0.22, max: 0.72 } };
      particles.size = { value: { min: 1.5, max: intensity === 'high' ? 5.5 : 4.5 } };
      particles.move = { enable: true, direction: 'bottom', speed: intensityMap[intensity].speed, straight: false, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'sparkles') {
      particles.color = { value: ['#fff7ad', '#f0abfc', '#93c5fd', '#ffffff'] };
      particles.shape = { type: 'star' };
      particles.opacity = { value: { min: 0.16, max: 0.95 }, animation: { enable: true, speed: 1.4 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1, max: intensity === 'high' ? 4.5 : 3.5 }, animation: { enable: true, speed: 2, sync: false } };
      particles.move = { enable: true, speed: 0.22 * intensityMap[intensity].rate, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'stars') {
      particles.color = { value: ['#fef3c7', '#dbeafe', '#f5d0fe'] };
      particles.shape = { type: 'star' };
      particles.opacity = { value: { min: 0.2, max: 0.9 }, animation: { enable: true, speed: 0.9 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1.2, max: intensity === 'high' ? 5 : 4 } };
      particles.move = { enable: true, speed: 0.16 * intensityMap[intensity].rate, random: true, outModes: { default: 'bounce' } };
      return built;
    }

    if (effect === 'hearts') {
      particles.shape = { type: 'emoji', options: { emoji: { value: ['\u2764\uFE0F', '\uD83D\uDC95', '\uD83D\uDC96'] } } };
      particles.opacity = { value: { min: 0.45, max: 0.9 } };
      particles.size = { value: { min: 12, max: intensity === 'high' ? 24 : 20 } };
      particles.move = { enable: true, direction: 'top', speed: 0.7 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'balloons') {
      particles.shape = { type: 'emoji', options: { emoji: { value: ['\uD83C\uDF88'] } } };
      particles.number.value = Math.max(8, Math.round(intensityMap[intensity].count * 0.45));
      particles.opacity = { value: { min: 0.55, max: 0.9 } };
      particles.size = { value: { min: 18, max: intensity === 'high' ? 34 : 28 } };
      particles.move = { enable: true, direction: 'top', speed: 0.55 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'confetti') {
      particles.color = { value: ['#ff0033', '#0057b8', '#fde047', '#22c55e', '#f97316', '#f0abfc'] };
      particles.shape = { type: ['square', 'polygon'], options: { polygon: { sides: 5 } } };
      particles.opacity = { value: { min: 0.45, max: 0.9 } };
      particles.size = { value: { min: 3, max: intensity === 'high' ? 8 : 6 } };
      particles.move = { enable: true, direction: 'bottom', speed: 1.05 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      particles.rotate = { value: { min: 0, max: 360 }, animation: { enable: true, speed: 12 * intensityMap[intensity].rate } };
      return built;
    }

    if (effect === 'fireworks') {
      particles.color = { value: ['#fef08a', '#fca5a5', '#93c5fd', '#c4b5fd', '#ffffff'] };
      particles.shape = { type: 'circle' };
      particles.number.value = Math.round(intensityMap[intensity].count * 0.75);
      particles.opacity = { value: { min: 0.15, max: 0.9 }, animation: { enable: true, speed: 1.8 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1, max: intensity === 'high' ? 4 : 3 } };
      particles.move = { enable: true, speed: 1.35 * intensityMap[intensity].rate, random: true, outModes: { default: 'out' } };
      particles.life = { duration: { value: { min: 1.1, max: 2.2 } }, count: 0 };
      return built;
    }

    if (effect === 'music_notes') {
      particles.shape = { type: 'char', options: { char: { value: ['♪', '♫', '♬'], font: 'Verdana', style: '', weight: '700' } } };
      particles.color = { value: ['#f0abfc', '#93c5fd', '#ffffff'] };
      particles.opacity = { value: { min: 0.28, max: 0.82 }, animation: { enable: true, speed: 0.8 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 11, max: intensity === 'high' ? 24 : 20 } };
      particles.move = { enable: true, direction: 'top', speed: 0.46 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      particles.rotate = { value: { min: -18, max: 18 }, animation: { enable: true, speed: 4 * intensityMap[intensity].rate } };
      return built;
    }

    if (effect === 'glow_bubbles') {
      particles.color = { value: ['#93c5fd', '#f0abfc', '#ffffff', '#c4b5fd'] };
      particles.shape = { type: 'circle' };
      particles.opacity = { value: { min: 0.12, max: 0.48 }, animation: { enable: true, speed: 0.7 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 8, max: intensity === 'high' ? 28 : 22 }, animation: { enable: true, speed: 1.4 * intensityMap[intensity].rate, sync: false } };
      particles.move = { enable: true, direction: 'top', speed: 0.28 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      particles.shadow = { enable: true, color: '#93c5fd', blur: 16 * intensityMap[intensity].glow };
      return built;
    }

    if (effect === 'petals') {
      particles.color = { value: ['#fecdd3', '#f9a8d4', '#fda4af', '#ffffff'] };
      particles.shape = { type: 'polygon', options: { polygon: { sides: 6 } } };
      particles.number.value = Math.round(intensityMap[intensity].count * 0.82);
      particles.opacity = { value: { min: 0.28, max: 0.74 } };
      particles.size = { value: { min: 4, max: intensity === 'high' ? 10 : 8 } };
      particles.move = { enable: true, direction: 'bottom', speed: 0.44 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      particles.rotate = { value: { min: 0, max: 360 }, animation: { enable: true, speed: 5 * intensityMap[intensity].rate } };
      return built;
    }

    if (effect === 'shooting_stars') {
      particles.color = { value: ['#ffffff', '#fef3c7', '#93c5fd'] };
      particles.shape = { type: 'star' };
      particles.number.value = Math.max(8, Math.round(intensityMap[intensity].count * 0.38));
      particles.opacity = { value: { min: 0.2, max: 0.9 }, animation: { enable: true, speed: 1.2 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1.5, max: intensity === 'high' ? 4.2 : 3.4 } };
      particles.move = { enable: true, direction: 'bottom-right', speed: 2.2 * intensityMap[intensity].rate, straight: true, random: false, outModes: { default: 'out' } };
      particles.shadow = { enable: true, color: '#ffffff', blur: 20 * intensityMap[intensity].glow };
      return built;
    }

    if (effect === 'concert_lights') {
      particles.color = { value: ['#ff0033', '#0057c8', '#f0abfc', '#ffffff'] };
      particles.shape = { type: 'circle' };
      particles.number.value = Math.max(10, Math.round(intensityMap[intensity].count * 0.48));
      particles.opacity = { value: { min: 0.12, max: 0.62 }, animation: { enable: true, speed: 1.8 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 16, max: intensity === 'high' ? 54 : 42 }, animation: { enable: true, speed: 1.1 * intensityMap[intensity].rate, sync: false } };
      particles.move = { enable: true, speed: 0.34 * intensityMap[intensity].rate, random: true, outModes: { default: 'bounce' } };
      particles.shadow = { enable: true, color: '#ffffff', blur: 24 * intensityMap[intensity].glow };
      return built;
    }

    if (effect === 'soft_flashes') {
      particles.color = { value: ['#ffffff', '#f0abfc', '#93c5fd'] };
      particles.shape = { type: 'circle' };
      particles.number.value = Math.max(8, Math.round(intensityMap[intensity].count * 0.32));
      particles.opacity = { value: { min: 0.08, max: 0.46 }, animation: { enable: true, speed: 2.2 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 24, max: intensity === 'high' ? 90 : 68 }, animation: { enable: true, speed: 1.8 * intensityMap[intensity].rate, sync: false } };
      particles.move = { enable: true, speed: 0.12 * intensityMap[intensity].rate, random: true, outModes: { default: 'bounce' } };
      particles.shadow = { enable: true, color: '#ffffff', blur: 34 * intensityMap[intensity].glow };
      return built;
    }

    return built;
  };

  const clearCustomEffect = () => {
    const root = document.getElementById(effectRootId);
    root?.querySelectorAll('[data-effect-item]').forEach((item) => item.remove());
  };

  const customLabel = (effect, index) => {
    if (effect === 'diamond_pilli') return 'Pilli';
    if (effect === 'hearts_red_blue') return index % 2 ? '♥' : '❤';
    if (effect === 'soccer_balls') return '⚽';
    if (effect === 'smiling_suns') return '☀';
    if (effect === 'glitter_butterflies') return '🦋';
    return '';
  };

  const applyCustomEffect = (root, effect, intensity) => {
    clearCustomEffect();
    const count = intensityMap[intensity].customCount;
    root.style.setProperty('--effect-rate', String(intensityMap[intensity].rate));
    root.style.setProperty('--effect-glow', String(intensityMap[intensity].glow));

    for (let index = 0; index < count; index += 1) {
      const item = document.createElement('span');
      item.className = 'global-site-effect-item';
      item.dataset.effectItem = effect;
      item.textContent = customLabel(effect, index);
      item.style.setProperty('--x', `${Math.random() * 100}%`);
      item.style.setProperty('--y', `${Math.random() * 100}%`);
      item.style.setProperty('--delay', `${-(Math.random() * 12).toFixed(2)}s`);
      item.style.setProperty('--dur', `${(8 + Math.random() * 9).toFixed(2)}s`);
      item.style.setProperty('--size', `${(0.72 + Math.random() * 0.86).toFixed(2)}`);
      item.style.setProperty('--drift', `${(18 + Math.random() * 54).toFixed(0)}px`);
      item.style.setProperty('--spin', `${(Math.random() > 0.5 ? 1 : -1) * (8 + Math.random() * 28).toFixed(0)}deg`);
      root.appendChild(item);
    }
  };

  const clearEffect = async () => {
    activeKey = '';
    const root = document.getElementById(effectRootId);
    if (root) {
      delete root.dataset.effect;
      delete root.dataset.intensity;
    }
    if (activeContainer) {
      activeContainer.destroy();
      activeContainer = null;
    }
    clearCustomEffect();
  };

  const applyGlobalSiteEffect = async (settings) => {
    const effect = normalizeEffect(settings?.siteEffect);
    const intensity = normalizeIntensity(settings?.effectIntensity);
    const root = document.getElementById(effectRootId);
    if (!root || reducedMotion() || effect === 'none') {
      await clearEffect();
      return;
    }

    root.dataset.effect = effect;
    root.dataset.intensity = intensity;

    if (customEffects.has(effect)) {
      if (activeContainer) {
        activeContainer.destroy();
        activeContainer = null;
      }
      const key = `${effect}:${intensity}`;
      if (activeKey === key) return;
      activeKey = key;
      applyCustomEffect(root, effect, intensity);
      return;
    }

    try {
      if (!engineReady) {
        await loadSlim(tsParticles);
        engineReady = true;
      }

      const built = buildOptions(effect, intensity);
      if (activeKey === built.key) return;
      if (activeContainer) {
        activeContainer.destroy();
        activeContainer = null;
      }
      clearCustomEffect();
      activeKey = built.key;
      activeContainer = await tsParticles.load({ id: effectRootId, element: root, options: built.options });
    } catch (error) {
      console.warn('Effetto speciale non avviato con tsParticles:', error);
    }
  };

  if (!window.__DDGPILLI_GLOBAL_SITE_EFFECT_READY) {
    window.__DDGPILLI_GLOBAL_SITE_EFFECT_READY = true;
    window.__DDGPILLI_APPLY_GLOBAL_SITE_EFFECT = applyGlobalSiteEffect;
    window.addEventListener('ddgpilli:site-settings-updated', (event) => {
      applyGlobalSiteEffect(event.detail || window.__DDGPILLI_SITE_SETTINGS || {});
    });
    window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', () => {
      applyGlobalSiteEffect(window.__DDGPILLI_SITE_SETTINGS || {});
    });
    applyGlobalSiteEffect(window.__DDGPILLI_SITE_SETTINGS || {});
  }
</script>

<style>
  .global-site-effect {
    position: fixed;
    inset: 0;
    z-index: 250;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.9;
    mix-blend-mode: screen;
  }

  .global-site-effect canvas {
    pointer-events: none !important;
  }

  .global-site-effect-item {
    position: absolute;
    left: var(--x);
    top: var(--y);
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    user-select: none;
    transform-origin: center;
    will-change: transform, opacity, filter;
    animation:
      ddgff-custom-float calc(var(--dur) / var(--effect-rate, 1)) ease-in-out infinite,
      ddgff-custom-pulse calc((var(--dur) * 0.42) / var(--effect-rate, 1)) ease-in-out infinite;
    animation-delay: var(--delay), calc(var(--delay) * 0.55);
  }

  .global-site-effect[data-effect="diamond_pilli"] {
    opacity: 0.98;
    mix-blend-mode: screen;
  }

  .global-site-effect[data-effect="diamond_pilli"] .global-site-effect-item {
    padding: 0.04em 0.22em 0.1em;
    border-radius: 999px;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: calc(0.88rem * var(--size));
    font-weight: 900;
    letter-spacing: 0.035em;
    color: #ffffff;
    background:
      linear-gradient(118deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.92) 32%, rgba(240, 171, 252, 0.52) 48%, rgba(147, 197, 253, 0.74) 68%, rgba(255, 255, 255, 0.18)),
      linear-gradient(90deg, #ffffff, #f5d0fe, #bfdbfe, #ffffff);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow:
      0 0 calc(8px * var(--effect-glow, 1)) rgba(255, 255, 255, 0.92),
      0 0 calc(18px * var(--effect-glow, 1)) rgba(240, 171, 252, 0.72),
      0 0 calc(30px * var(--effect-glow, 1)) rgba(147, 197, 253, 0.48);
    filter: drop-shadow(0 0 calc(9px * var(--effect-glow, 1)) rgba(255, 255, 255, 0.78));
  }

  .global-site-effect[data-effect="diamond_pilli"] .global-site-effect-item::before,
  .global-site-effect[data-effect="diamond_pilli"] .global-site-effect-item::after {
    content: "";
    position: absolute;
    inset: -0.26em -0.42em;
    border-radius: inherit;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 28%, rgba(255, 255, 255, 0.95) 0 1px, transparent 3px),
      radial-gradient(circle at 76% 18%, rgba(255, 255, 255, 0.88) 0 1px, transparent 4px),
      radial-gradient(circle at 62% 78%, rgba(191, 219, 254, 0.84) 0 1.5px, transparent 5px);
    opacity: 0.86;
    animation: ddgff-glitter 1.4s ease-in-out infinite;
  }

  .global-site-effect[data-effect="diamond_pilli"] .global-site-effect-item::after {
    inset: -0.42em -0.62em;
    opacity: 0.48;
    filter: blur(4px);
    animation-duration: 2.1s;
    animation-delay: -0.7s;
  }

  .global-site-effect[data-effect="glitter_butterflies"] .global-site-effect-item {
    font-size: calc(1.28rem * var(--size));
    color: #f5d0fe;
    text-shadow:
      0 0 calc(8px * var(--effect-glow, 1)) rgba(255, 255, 255, 0.9),
      0 0 calc(18px * var(--effect-glow, 1)) rgba(240, 171, 252, 0.74),
      0 0 calc(26px * var(--effect-glow, 1)) rgba(147, 197, 253, 0.5);
    filter: drop-shadow(calc(-10px * var(--size)) 5px 8px rgba(240, 171, 252, 0.28));
    animation:
      ddgff-butterfly-flight calc(var(--dur) / var(--effect-rate, 1)) ease-in-out infinite,
      ddgff-custom-pulse calc((var(--dur) * 0.36) / var(--effect-rate, 1)) ease-in-out infinite;
  }

  .global-site-effect[data-effect="glitter_butterflies"] .global-site-effect-item::after {
    content: "";
    position: absolute;
    width: 1.8em;
    height: 0.26em;
    right: 42%;
    top: 58%;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.7), rgba(240, 171, 252, 0.25), transparent);
    filter: blur(4px);
    opacity: 0.78;
    transform: rotate(-18deg);
  }

  .global-site-effect[data-effect="hearts_red_blue"] .global-site-effect-item {
    font-size: calc(1.08rem * var(--size));
    color: #ff0033;
    text-shadow:
      0 0 calc(10px * var(--effect-glow, 1)) currentColor,
      0 0 calc(20px * var(--effect-glow, 1)) rgba(255, 255, 255, 0.38);
    animation:
      ddgff-heart-rise calc(var(--dur) / var(--effect-rate, 1)) ease-in-out infinite,
      ddgff-heartbeat calc(1.2s / var(--effect-rate, 1)) ease-in-out infinite;
  }

  .global-site-effect[data-effect="hearts_red_blue"] .global-site-effect-item:nth-child(2n) {
    color: #0057c8;
  }

  .global-site-effect[data-effect="soccer_balls"] .global-site-effect-item {
    font-size: calc(1.04rem * var(--size));
    filter: drop-shadow(0 0 calc(10px * var(--effect-glow, 1)) rgba(255, 255, 255, 0.42));
    animation:
      ddgff-soccer-drift calc(var(--dur) / var(--effect-rate, 1)) ease-in-out infinite,
      ddgff-soccer-spin calc(2.8s / var(--effect-rate, 1)) linear infinite;
  }

  .global-site-effect[data-effect="smiling_suns"] .global-site-effect-item {
    width: calc(1.55rem * var(--size));
    height: calc(1.55rem * var(--size));
    border-radius: 50%;
    font-size: 0;
    background:
      radial-gradient(circle at 36% 38%, #7c2d12 0 1.3px, transparent 1.8px),
      radial-gradient(circle at 64% 38%, #7c2d12 0 1.3px, transparent 1.8px),
      radial-gradient(ellipse at 50% 64%, transparent 0 34%, #7c2d12 35% 42%, transparent 43%),
      radial-gradient(circle, #fff7ad 0 23%, #facc15 47%, #f97316 100%);
    box-shadow:
      0 0 calc(12px * var(--effect-glow, 1)) rgba(254, 240, 138, 0.95),
      0 0 calc(26px * var(--effect-glow, 1)) rgba(249, 115, 22, 0.56);
    animation:
      ddgff-sun-float calc(var(--dur) / var(--effect-rate, 1)) ease-in-out infinite,
      ddgff-sun-spin calc(7s / var(--effect-rate, 1)) linear infinite;
  }

  .global-site-effect[data-effect="smiling_suns"] .global-site-effect-item::before {
    content: "";
    position: absolute;
    inset: -28%;
    border-radius: inherit;
    background: repeating-conic-gradient(from 0deg, rgba(254, 240, 138, 0.86) 0 9deg, transparent 9deg 18deg);
    z-index: -1;
    filter: blur(0.4px);
  }

  .global-site-effect[data-intensity="low"] .global-site-effect-item {
    opacity: 0.68;
  }

  .global-site-effect[data-intensity="high"] .global-site-effect-item {
    opacity: 0.96;
  }

  .global-site-effect::before,
  .global-site-effect::after {
    content: "";
    position: absolute;
    inset: -12%;
    pointer-events: none;
  }

  .global-site-effect[data-effect="sparkles"]::before,
  .global-site-effect[data-effect="sparkles"]::after {
    background-image:
      radial-gradient(circle, rgba(255, 255, 255, 1) 0 1.8px, transparent 3.2px),
      radial-gradient(circle, rgba(255, 247, 173, 0.95) 0 1.6px, transparent 3px),
      radial-gradient(circle, rgba(240, 171, 252, 0.86) 0 1.7px, transparent 3px),
      radial-gradient(circle, rgba(147, 197, 253, 0.82) 0 1.5px, transparent 2.8px);
