<div class="global-site-effect" id="global-site-effect" aria-hidden="true"></div>

<script>
  import { tsParticles } from '@tsparticles/engine';
  import { loadSlim } from '@tsparticles/slim';

  const effectRootId = 'global-site-effect';
  const validEffects = new Set(['auto', 'none', 'sparkles', 'snow', 'hearts', 'balloons', 'confetti', 'fireworks', 'stars']);
  const validIntensities = new Set(['low', 'medium', 'high']);
  const intensityMap = {
    low: { count: 18, speed: 0.55, rate: 0.65 },
    medium: { count: 34, speed: 0.9, rate: 1 },
    high: { count: 58, speed: 1.25, rate: 1.45 },
  };

  let engineReady = false;
  let activeContainer = null;
  let activeKey = '';

  const reducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const normalizeEffect = (value) => {
    const effect = String(value || 'none').trim();
    if (!validEffects.has(effect)) return 'none';
    return effect === 'auto' ? 'none' : effect;
  };

  const normalizeIntensity = (value) => {
    const intensity = String(value || 'medium').trim();
    return validIntensities.has(intensity) ? intensity : 'medium';
  };

  const baseOptions = (effect, intensity) => ({
    key: `${effect}:${intensity}`,
    options: {
      fullScreen: { enable: false },
      detectRetina: true,
      fpsLimit: intensity === 'high' ? 50 : 42,
      background: { color: { value: 'transparent' } },
      interactivity: { events: { resize: true } },
      particles: {
        number: { value: intensityMap[intensity].count, density: { enable: true, width: 1100, height: 900 } },
        collisions: { enable: false },
        opacity: { value: { min: 0.25, max: 0.85 } },
        size: { value: { min: 2, max: 5 } },
        move: {
          enable: true,
          speed: intensityMap[intensity].speed,
          outModes: { default: 'out' },
        },
      },
    },
  });

  const buildOptions = (effect, intensity) => {
    const built = baseOptions(effect, intensity);
    const particles = built.options.particles;

    if (effect === 'snow') {
      particles.color = { value: ['#ffffff', '#dbeafe', '#bae6fd'] };
      particles.shape = { type: 'circle' };
      particles.number.value = Math.round(intensityMap[intensity].count * 1.25);
      particles.opacity = { value: { min: 0.22, max: 0.72 } };
      particles.size = { value: { min: 1.5, max: intensity === 'high' ? 5.5 : 4.5 } };
      particles.move = { enable: true, direction: 'bottom', speed: intensityMap[intensity].speed, straight: false, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'sparkles') {
      particles.color = { value: ['#fff7ad', '#f0abfc', '#93c5fd', '#ffffff'] };
      particles.shape = { type: 'star' };
      particles.opacity = { value: { min: 0.16, max: 0.95 }, animation: { enable: true, speed: 1.4 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1, max: intensity === 'high' ? 4.5 : 3.5 }, animation: { enable: true, speed: 2, sync: false } };
      particles.move = { enable: true, speed: 0.22 * intensityMap[intensity].rate, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'stars') {
      particles.color = { value: ['#fef3c7', '#dbeafe', '#f5d0fe'] };
      particles.shape = { type: 'star' };
      particles.opacity = { value: { min: 0.2, max: 0.9 }, animation: { enable: true, speed: 0.9 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1.2, max: intensity === 'high' ? 5 : 4 } };
      particles.move = { enable: true, speed: 0.16 * intensityMap[intensity].rate, random: true, outModes: { default: 'bounce' } };
      return built;
    }

    if (effect === 'hearts') {
      particles.shape = { type: 'emoji', options: { emoji: { value: ['\u2764\uFE0F', '\uD83D\uDC95', '\uD83D\uDC96'] } } };
      particles.opacity = { value: { min: 0.45, max: 0.9 } };
      particles.size = { value: { min: 12, max: intensity === 'high' ? 24 : 20 } };
      particles.move = { enable: true, direction: 'top', speed: 0.7 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'balloons') {
      particles.shape = { type: 'emoji', options: { emoji: { value: ['\uD83C\uDF88'] } } };
      particles.number.value = Math.max(8, Math.round(intensityMap[intensity].count * 0.45));
      particles.opacity = { value: { min: 0.55, max: 0.9 } };
      particles.size = { value: { min: 18, max: intensity === 'high' ? 34 : 28 } };
      particles.move = { enable: true, direction: 'top', speed: 0.55 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      return built;
    }

    if (effect === 'confetti') {
      particles.color = { value: ['#ff0033', '#0057b8', '#fde047', '#22c55e', '#f97316', '#f0abfc'] };
      particles.shape = { type: ['square', 'polygon'], options: { polygon: { sides: 5 } } };
      particles.opacity = { value: { min: 0.45, max: 0.9 } };
      particles.size = { value: { min: 3, max: intensity === 'high' ? 8 : 6 } };
      particles.move = { enable: true, direction: 'bottom', speed: 1.05 * intensityMap[intensity].rate, straight: false, random: true, outModes: { default: 'out' } };
      particles.rotate = { value: { min: 0, max: 360 }, animation: { enable: true, speed: 12 * intensityMap[intensity].rate } };
      return built;
    }

    if (effect === 'fireworks') {
      particles.color = { value: ['#fef08a', '#fca5a5', '#93c5fd', '#c4b5fd', '#ffffff'] };
      particles.shape = { type: 'circle' };
      particles.number.value = Math.round(intensityMap[intensity].count * 0.75);
      particles.opacity = { value: { min: 0.15, max: 0.9 }, animation: { enable: true, speed: 1.8 * intensityMap[intensity].rate, sync: false } };
      particles.size = { value: { min: 1, max: intensity === 'high' ? 4 : 3 } };
      particles.move = { enable: true, speed: 1.35 * intensityMap[intensity].rate, random: true, outModes: { default: 'out' } };
      particles.life = { duration: { value: { min: 1.1, max: 2.2 } }, count: 0 };
      return built;
    }

    return built;
  };

  const clearEffect = async () => {
    activeKey = '';
    const root = document.getElementById(effectRootId);
    if (root) {
      delete root.dataset.effect;
      delete root.dataset.intensity;
    }
    if (activeContainer) {
      activeContainer.destroy();
      activeContainer = null;
    }
  };

  const applyGlobalSiteEffect = async (settings) => {
    const effect = normalizeEffect(settings?.siteEffect);
    const intensity = normalizeIntensity(settings?.effectIntensity);
    const root = document.getElementById(effectRootId);
    if (!root || reducedMotion() || effect === 'none') {
      await clearEffect();
      return;
    }

    root.dataset.effect = effect;
    root.dataset.intensity = intensity;

    try {
      if (!engineReady) {
        await loadSlim(tsParticles);
        engineReady = true;
      }

      const built = buildOptions(effect, intensity);
      if (activeKey === built.key) return;
      if (activeContainer) {
        activeContainer.destroy();
        activeContainer = null;
      }
      activeKey = built.key;
      activeContainer = await tsParticles.load({ id: effectRootId, element: root, options: built.options });
    } catch (error) {
      console.warn('Effetto speciale non avviato con tsParticles:', error);
    }
  };

  if (!window.__DDGPILLI_GLOBAL_SITE_EFFECT_READY) {
    window.__DDGPILLI_GLOBAL_SITE_EFFECT_READY = true;
    window.__DDGPILLI_APPLY_GLOBAL_SITE_EFFECT = applyGlobalSiteEffect;
    window.addEventListener('ddgpilli:site-settings-updated', (event) => {
      applyGlobalSiteEffect(event.detail || window.__DDGPILLI_SITE_SETTINGS || {});
    });
    window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', () => {
      applyGlobalSiteEffect(window.__DDGPILLI_SITE_SETTINGS || {});
    });
    applyGlobalSiteEffect(window.__DDGPILLI_SITE_SETTINGS || {});
  }
</script>

<style>
  .global-site-effect {
    position: fixed;
    inset: 0;
    z-index: 250;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.9;
    mix-blend-mode: screen;
  }

  .global-site-effect canvas {
    pointer-events: none !important;
  }

  .global-site-effect::before,
  .global-site-effect::after {
    content: "";
    position: absolute;
    inset: -12%;
    pointer-events: none;
  }

  .global-site-effect[data-effect="sparkles"]::before,
  .global-site-effect[data-effect="sparkles"]::after {
    background-image:
      radial-gradient(circle, rgba(255, 255, 255, 1) 0 1.8px, transparent 3.2px),
      radial-gradient(circle, rgba(255, 247, 173, 0.95) 0 1.6px, transparent 3px),
      radial-gradient(circle, rgba(240, 171, 252, 0.86) 0 1.7px, transparent 3px),
      radial-gradient(circle, rgba(147, 197, 253, 0.82) 0 1.5px, transparent 2.8px);
    background-size: 76px 76px, 118px 118px, 154px 154px, 204px 204px;
    background-position: 8px 18px, 44px 66px, 92px 24px, 120px 132px;
    animation: ddgff-sparkles-drift 7s linear infinite, ddgff-sparkles-pulse 1.9s ease-in-out infinite;
  }

  .global-site-effect[data-effect="sparkles"]::after {
    inset: -18%;
    opacity: 0.62;
    filter: blur(0.5px);
    transform: rotate(12deg);
    animation-duration: 13s, 3.2s;
    animation-direction: reverse, alternate;
  }

  .global-site-effect[data-effect="snow"]::before,
  .global-site-effect[data-effect="snow"]::after {
    background-image:
      radial-gradient(circle, rgba(255, 255, 255, 0.95) 0 2px, transparent 3.4px),
      radial-gradient(circle, rgba(219, 234, 254, 0.82) 0 1.5px, transparent 3px),
      radial-gradient(circle, rgba(186, 230, 253, 0.7) 0 1.2px, transparent 2.6px);
    background-size: 80px 80px, 126px 126px, 190px 190px;
    background-position: 12px 18px, 58px 72px, 128px 36px;
    animation: ddgff-fall 8s linear infinite;
  }

  .global-site-effect[data-effect="snow"]::after {
    opacity: 0.65;
    animation-duration: 12s;
    animation-delay: -4s;
  }

  .global-site-effect[data-effect="confetti"]::before,
  .global-site-effect[data-effect="confetti"]::after {
    background-image:
      linear-gradient(45deg, #ff0033 0 7px, transparent 7px),
      linear-gradient(-35deg, #0057c8 0 8px, transparent 8px),
      linear-gradient(20deg, #fde047 0 7px, transparent 7px),
      linear-gradient(-20deg, #22c55e 0 8px, transparent 8px);
    background-size: 90px 90px, 128px 128px, 156px 156px, 210px 210px;
    background-position: 16px 10px, 48px 82px, 92px 24px, 156px 122px;
    animation: ddgff-fall 5.5s linear infinite, ddgff-sway 2.4s ease-in-out infinite;
  }

  .global-site-effect[data-effect="confetti"]::after {
    opacity: 0.7;
    animation-duration: 8s, 3s;
    animation-delay: -2s;
  }

  .global-site-effect[data-effect="stars"]::before,
  .global-site-effect[data-effect="stars"]::after,
  .global-site-effect[data-effect="fireworks"]::before,
  .global-site-effect[data-effect="fireworks"]::after {
    background-image:
      radial-gradient(circle, rgba(254, 243, 199, 1) 0 2px, transparent 3.6px),
      radial-gradient(circle, rgba(219, 234, 254, 0.95) 0 1.7px, transparent 3px),
      radial-gradient(circle, rgba(245, 208, 254, 0.86) 0 1.6px, transparent 3px);
    background-size: 86px 86px, 142px 142px, 220px 220px;
    background-position: 22px 30px, 82px 18px, 132px 96px;
    animation: ddgff-sparkles-pulse 1.8s ease-in-out infinite, ddgff-sparkles-drift 10s linear infinite;
  }

  .global-site-effect[data-effect="fireworks"]::before,
  .global-site-effect[data-effect="fireworks"]::after {
    background-image:
      radial-gradient(circle, rgba(254, 240, 138, 1) 0 2px, transparent 3px),
      radial-gradient(circle, rgba(252, 165, 165, 0.95) 0 2px, transparent 4px),
      radial-gradient(circle, rgba(147, 197, 253, 0.95) 0 1.8px, transparent 4px),
      radial-gradient(circle, rgba(255, 255, 255, 0.9) 0 1px, transparent 9px);
    background-size: 120px 120px, 180px 180px, 240px 240px, 300px 300px;
    animation-duration: 1.2s, 7s;
  }

  .global-site-effect[data-effect="hearts"]::before,
  .global-site-effect[data-effect="hearts"]::after,
  .global-site-effect[data-effect="balloons"]::before,
  .global-site-effect[data-effect="balloons"]::after {
    white-space: pre;
    color: rgba(255, 255, 255, 0.92);
    font-size: 24px;
    line-height: 72px;
    text-shadow: 0 0 14px rgba(255, 255, 255, 0.45);
    animation: ddgff-float-up 9s linear infinite;
  }

  .global-site-effect[data-effect="hearts"]::before {
    content: "❤   💕      💖   ❤      💕\A    💖      ❤   💕      💖\A 💕     ❤      💖    💕     ❤\A    ❤   💖      💕    ❤";
  }

  .global-site-effect[data-effect="hearts"]::after {
    content: "💕      ❤   💖      💕   ❤\A   ❤      💕     ❤      💖\A 💖   💕      ❤   💖      💕";
    opacity: 0.68;
    animation-duration: 13s;
    animation-delay: -5s;
  }

  .global-site-effect[data-effect="balloons"]::before {
    content: "🎈        🎈      🎈        🎈\A    🎈       🎈        🎈\A 🎈      🎈       🎈       🎈";
    font-size: 28px;
  }

  .global-site-effect[data-effect="balloons"]::after {
    content: "   🎈       🎈       🎈\A 🎈       🎈        🎈      🎈";
    font-size: 30px;
    opacity: 0.72;
    animation-duration: 15s;
    animation-delay: -6s;
  }

  .global-site-effect[data-effect="sparkles"][data-intensity="low"] {
    opacity: 0.62;
  }

  .global-site-effect[data-effect="sparkles"][data-intensity="high"] {
    opacity: 1;
  }

  .global-site-effect[data-effect="sparkles"][data-intensity="high"]::before,
  .global-site-effect[data-effect="sparkles"][data-intensity="high"]::after {
    background-size: 68px 68px, 104px 104px, 140px 140px, 188px 188px;
    animation-duration: 7s, 1.8s;
  }

  .global-site-effect[data-effect="sparkles"][data-intensity="low"]::before,
  .global-site-effect[data-effect="sparkles"][data-intensity="low"]::after {
    background-size: 140px 140px, 190px 190px, 260px 260px, 320px 320px;
    animation-duration: 14s, 3.6s;
  }

  @keyframes ddgff-sparkles-drift {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(56px, 72px, 0);
    }
  }

  @keyframes ddgff-sparkles-pulse {
    0%, 100% {
      opacity: 0.48;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes ddgff-fall {
    from {
      transform: translate3d(0, -8%, 0);
    }
    to {
      transform: translate3d(42px, 18%, 0);
    }
  }

  @keyframes ddgff-sway {
    0%, 100% {
      margin-left: -18px;
    }
    50% {
      margin-left: 18px;
    }
  }

  @keyframes ddgff-float-up {
    from {
      transform: translate3d(0, 18%, 0);
    }
    to {
      transform: translate3d(38px, -18%, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .global-site-effect::before,
    .global-site-effect::after {
      display: none !important;
      animation: none !important;
    }
  }
</style>
