---
export interface Props {
  dedication: {
    id: string;
    date: string;
    song_title: string;
    artist: string;
    voteAverage?: number;
    thoughtsText?: string;
    reactions?: Record<string, number>;
    votes?: Array<Record<string, unknown>>;
    thoughts?: Array<Record<string, unknown>>;
    reactionEntries?: Array<Record<string, unknown>>;
  };
  mode: 'button' | 'reactions';
}

const { dedication, mode } = Astro.props;
const data = {
  id: dedication.id,
  date: dedication.date,
  title: dedication.song_title,
  artist: dedication.artist,
  voteAverage: dedication.voteAverage ?? null,
  thoughtsText: dedication.thoughtsText ?? '',
  reactions: dedication.reactions ?? {},
  votes: dedication.votes ?? [],
  thoughts: dedication.thoughts ?? [],
  reactionEntries: dedication.reactionEntries ?? [],
};
---

{mode === 'button' ? (
  <div class="plus-vote" data-plus-vote={JSON.stringify(data)} data-site-config-target="plusVote">
    <button class="btn btn-secondary btn-lg plus-vote-open" type="button" data-plus-vote-open>
      ⭐ Votami Plus
    </button>

    <div class="plus-vote-modal" data-plus-vote-modal hidden>
      <div class="plus-vote-dialog" role="dialog" aria-modal="true" aria-labelledby={`plus-vote-title-${dedication.id}`}>
        <button class="plus-vote-close" type="button" aria-label="Chiudi" data-plus-vote-close>×</button>
        <p class="plus-vote-kicker">Pensiero di Pilly</p>
        <h2 id={`plus-vote-title-${dedication.id}`}>{dedication.song_title}</h2>
        <p class="plus-vote-artist">{dedication.artist}</p>
        <form class="plus-vote-form" data-plus-vote-form>
          <label>
            <span>Voto da 1 a 10</span>
            <input data-plus-vote-score type="text" inputmode="numeric" pattern="[1-9]|10" autocomplete="off" required />
          </label>
          <label class="plus-vote-identity-label" data-plus-vote-identity-label>
            <span>Il tuo nome</span>
            <input data-plus-vote-identity type="text" readonly tabindex="-1" placeholder="(inserisci nome e cognome dalla prima volta)" />
          </label>
          <label>
            <span>Pensiero di Pilly</span>
            <textarea data-plus-vote-thought rows="8" placeholder="Scrivi un pensiero, anche breve..."></textarea>
          </label>
          <div class="plus-vote-actions">
            <button class="btn btn-primary" type="submit" data-plus-vote-submit>Salva voto</button>
            <button class="btn btn-secondary" type="button" data-plus-vote-cancel>Annulla</button>
          </div>
          <p class="plus-vote-status" data-plus-vote-status aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
) : (
  <div class="quick-reactions" data-quick-reactions={JSON.stringify(data)} aria-label="Reazioni rapide">
    <button type="button" data-reaction="down" aria-label="Non mi piace"><span>👎</span><strong data-count="down">0</strong></button>
    <button type="button" data-reaction="like" aria-label="Mi piace"><span>👍</span><strong data-count="like">0</strong></button>
    <button type="button" data-reaction="heart" aria-label="Molto romantica"><span>❤️</span><strong data-count="heart">0</strong></button>
    <button type="button" data-reaction="sun" aria-label="Mi porta allegria"><span>☀️</span><strong data-count="sun">0</strong></button>
  </div>
)}

<style>
  .quick-reactions {
    position: relative;
  }

  .reaction-detail-toggle {
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.12);
    color: inherit;
  }

  .reaction-detail-popover {
    position: absolute;
    z-index: 20;
    top: calc(100% + 0.6rem);
    right: 0;
    min-width: min(260px, 86vw);
    padding: 0.85rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 8px;
    background: rgba(5, 12, 28, 0.94);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
    color: #fff;
    text-align: left;
  }

  .reaction-detail-title {
    margin-bottom: 0.55rem;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .reaction-detail-list {
    display: grid;
    gap: 0.35rem;
    font-size: 0.92rem;
    line-height: 1.35;
  }
</style>

<script>
  const voteStoreKey = 'ddgpilli-plus-votes';
  const reactionCountKey = 'ddgpilli-reaction-counts';
  const reactionChoiceKey = 'ddgpilli-reaction-choice';
  const reactionKeys = ['down', 'like', 'heart', 'sun'];
  const reactionLabels = {
    down: '👎',
    like: '👍',
    heart: '❤️',
    sun: '☀️',
  };

  function readObject(key) {
    try {
      const value = JSON.parse(localStorage.getItem(key) || '{}');
      return value && typeof value === 'object' ? value : {};
    } catch {
      return {};
    }
  }

  function writeObject(key, value) {
    localStorage.setItem(key, JSON.stringify(value));
    window.dispatchEvent(new CustomEvent('ddgpilli:stats-updated'));
  }

  function feedbackApiUrl() {
    return document.querySelector('meta[name="ddgpilli-feedback-api"]')?.getAttribute('content')?.trim()
      || window.__DDGPILLI_FEEDBACK_API_URL
      || '';
  }

  async function postFeedback(path, payload) {
    const baseUrl = feedbackApiUrl();
    if (!baseUrl) throw new Error('API feedback non configurata: impossibile salvare in modo persistente.');
    const response = await fetch(`${baseUrl.replace(/\/$/, '')}${path}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const result = await response.json().catch(() => ({}));
    if (!response.ok || result.ok === false) {
      throw new Error(result.error || 'Salvataggio persistente non riuscito.');
    }
    return result;
  }

  async function fetchFeedback(dedicationId) {
    const baseUrl = feedbackApiUrl();
    if (!baseUrl || !dedicationId) return null;
    const response = await fetch(`${baseUrl.replace(/\/$/, '')}/feedback?id=${encodeURIComponent(dedicationId)}`, {
      cache: 'no-store',
    });
    const result = await response.json().catch(() => ({}));
    if (!response.ok || result.ok === false) return null;
    return result.feedback || null;
  }

  function parseData(node) {
    const raw = node.getAttribute('data-plus-vote') || node.getAttribute('data-quick-reactions') || '{}';
    try {
      return JSON.parse(raw);
    } catch {
      return {};
    }
  }

  function normalizeCounts(counts) {
    return reactionKeys.reduce((acc, key) => {
      acc[key] = Math.max(0, Number(counts?.[key] || 0));
      return acc;
    }, {});
  }

  function feedbackReactions(result) {
    return result?.reactions || result?.feedback?.reactions || null;
  }

  function currentIdentity() {
    return window.__DDGPILLI?.getUserIdentity?.() || {};
  }

  function displayName(identity) {
    return identity.displayName || [identity.nome, identity.cognome].filter(Boolean).join(' ').trim() || 'Utente';
  }

  function normalizeUserKey(value) {
    return String(value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim()
      .toLowerCase()
      .replace(/\s+/g, ' ')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 160);
  }

  function identityUserKey(identity) {
    return normalizeUserKey(identity.userKey || [identity.nome, identity.cognome].filter(Boolean).join(' ') || displayName(identity) || identity.email || identity.userId);
  }

  function entryUserKey(item) {
    return normalizeUserKey(item?.userKey || item?.user_key || item?.userName || item?.user_name || item?.userId || item?.user_id);
  }

  function currentUserVote(feedback, identity) {
    const userKey = identityUserKey(identity);
    const votes = Array.isArray(feedback?.votes) ? feedback.votes : [];
    return votes.find((item) => entryUserKey(item) === userKey) || null;
  }

  function currentUserThought(feedback, identity) {
    const userKey = identityUserKey(identity);
    const thoughts = Array.isArray(feedback?.thoughts) ? feedback.thoughts : [];
    return thoughts.find((item) => entryUserKey(item) === userKey) || null;
  }

  function currentUserReaction(feedback, identity) {
    const userKey = identityUserKey(identity);
    const entries = Array.isArray(feedback?.reactionEntries) ? feedback.reactionEntries : [];
    return entries.find((item) => entryUserKey(item) === userKey)?.value || '';
  }

  function reactionChoiceId(dedicationId, identity = currentIdentity()) {
    return `${dedicationId}:${identityUserKey(identity) || 'anonymous'}`;
  }

  function apiResultToLocalVote(data, votePayload) {
    return {
      id: data.id,
      date: data.date,
      title: data.title,
      artist: data.artist,
      votes: [{
        userId: votePayload.userId,
        userKey: votePayload.userKey,
        userName: votePayload.userName,
        value: votePayload.voteValue,
        createdAt: votePayload.updatedAt,
        updatedAt: votePayload.updatedAt,
      }],
      thoughts: votePayload.thoughtText ? [{
        userId: votePayload.userId,
        userKey: votePayload.userKey,
        userName: votePayload.userName,
        text: votePayload.thoughtText,
        createdAt: votePayload.updatedAt,
        updatedAt: votePayload.updatedAt,
      }] : [],
      voteAverage: votePayload.voteValue,
      thoughtsText: votePayload.thoughtText ? `[${votePayload.userName}] ${votePayload.thoughtText}` : '',
    };
  }

  function initPlusVotes() {
    document.querySelectorAll('[data-plus-vote]').forEach((root) => {
      if (root.dataset.ready === 'true') return;
      root.dataset.ready = 'true';

      const data = parseData(root);
      const modal = root.querySelector('[data-plus-vote-modal]');
      const open = root.querySelector('[data-plus-vote-open]');
      const close = root.querySelector('[data-plus-vote-close]');
      const cancel = root.querySelector('[data-plus-vote-cancel]');
      const form = root.querySelector('[data-plus-vote-form]');
      const score = root.querySelector('[data-plus-vote-score]');
      const thought = root.querySelector('[data-plus-vote-thought]');
      const identityInput = root.querySelector('[data-plus-vote-identity]');
      const status = root.querySelector('[data-plus-vote-status]');
      const submit = root.querySelector('[data-plus-vote-submit]');
      let serverFeedback = null;

      // Precompila il campo nome dalla identity salvata
      const prefillIdentity = () => {
        if (!(identityInput instanceof HTMLInputElement)) return;
        const identity = window.__DDGPILLI?.getUserIdentity?.() || {};
        const fullName = displayName(identity);
        identityInput.value = fullName || '(nome non impostato)';
      };

      if (modal instanceof HTMLElement && modal.parentElement !== document.body) {
        document.body.appendChild(modal);
      }

      const fillForm = async () => {
        if (feedbackApiUrl()) {
          try {
            serverFeedback = await fetchFeedback(data.id);
          } catch (error) {
            console.warn('Feedback non recuperato:', error);
            serverFeedback = null;
            if (status instanceof HTMLElement) {
              status.textContent = 'Voto salvato non recuperabile: controlla che la feedback API sia attiva.';
            }
          }
        } else if (status instanceof HTMLElement) {
          status.textContent = 'API feedback non configurata: il voto non puo essere salvato.';
        }
        const identity = currentIdentity();
        const source = serverFeedback || data;
        const savedVote = currentUserVote(source, identity);
        const savedThought = currentUserThought(source, identity);
        if (score instanceof HTMLInputElement) score.value = savedVote?.value ? String(savedVote.value) : '';
        if (thought instanceof HTMLTextAreaElement) thought.value = savedThought?.text || '';
        if (status instanceof HTMLElement && savedVote?.value) {
          status.textContent = 'Puoi modificare il tuo voto gia salvato.';
        }
      };

      const hide = () => {
        if (modal instanceof HTMLElement) modal.hidden = true;
        document.body.classList.remove('plus-vote-is-open');
      };

      open?.addEventListener('click', async () => {
        // Se nome/cognome non presenti, chiede prima l'identità
        if (window.__DDGPILLI?.hasIdentity && !window.__DDGPILLI.hasIdentity()) {
          window.__DDGPILLI.showIdentityModal?.();
          return;
        }
        prefillIdentity();
        if (status instanceof HTMLElement) status.textContent = feedbackApiUrl() ? 'Caricamento voto salvato...' : '';
        await fillForm();
        if (modal instanceof HTMLElement) modal.hidden = false;
        document.body.classList.add('plus-vote-is-open');
        if (score instanceof HTMLInputElement) score.focus();
      });
      close?.addEventListener('click', hide);
      cancel?.addEventListener('click', hide);
      modal?.addEventListener('click', (event) => {
        if (event.target === modal) hide();
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const value = Number(score?.value || 0);
        if (!Number.isInteger(value) || value < 1 || value > 10) {
          if (status instanceof HTMLElement) status.textContent = 'Inserisci un voto intero da 1 a 10.';
          return;
        }

        const identity = currentIdentity();
        const votePayload = {
          id: data.id,
          date: data.date,
          title: data.title,
          artist: data.artist,
          voteValue: value,
          thoughtText: thought instanceof HTMLTextAreaElement ? thought.value.trim() : '',
          userId: identity.userId || '',
          userKey: identityUserKey(identity),
          userName: displayName(identity),
          nome: identity.nome || '',
          cognome: identity.cognome || '',
          updatedAt: new Date().toISOString(),
        };

        if (status instanceof HTMLElement) status.textContent = 'Salvataggio in corso...';
        if (submit instanceof HTMLButtonElement) submit.disabled = true;

        let apiResult = null;
        try {
          apiResult = await postFeedback('/save_vote', votePayload);
          votePayload.updatedAt = apiResult.updated_at || votePayload.updatedAt;
        } catch (error) {
          console.error('Salvataggio voto fallito:', error);
          if (status instanceof HTMLElement) {
            status.textContent = error instanceof Error ? error.message : 'Salvataggio persistente non riuscito.';
          }
          if (submit instanceof HTMLButtonElement) submit.disabled = false;
          return;
        }

        const voteStore = readObject(voteStoreKey);
        voteStore[data.id] = apiResultToLocalVote(data, votePayload);
        writeObject(voteStoreKey, voteStore);
        if (status instanceof HTMLElement) {
          status.textContent = 'Voto salvato nel dataset.';
        }
        if (submit instanceof HTMLButtonElement) submit.disabled = false;
        window.setTimeout(hide, 500);
      });
    });
  }

  function initReactions() {
    document.querySelectorAll('[data-quick-reactions]').forEach((root) => {
      if (root.dataset.ready === 'true') return;
      root.dataset.ready = 'true';

      const data = parseData(root);
      const initialCounts = normalizeCounts(data.reactions);
      let serverFeedback = null;
      let detailButton = root.querySelector('[data-reaction-detail-toggle]');
      let detailPopover = root.querySelector('[data-reaction-detail-popover]');
      let detailList = root.querySelector('[data-reaction-detail-list]');

      if (!(detailButton instanceof HTMLButtonElement)) {
        detailButton = document.createElement('button');
        detailButton.type = 'button';
        detailButton.className = 'reaction-detail-toggle';
        detailButton.dataset.reactionDetailToggle = 'true';
        detailButton.setAttribute('aria-label', 'Dettaglio reaction');
        detailButton.textContent = '💬';
        root.append(detailButton);
      }
      if (!(detailPopover instanceof HTMLElement)) {
        detailPopover = document.createElement('div');
        detailPopover.className = 'reaction-detail-popover';
        detailPopover.dataset.reactionDetailPopover = 'true';
        detailPopover.hidden = true;
        detailPopover.innerHTML = '<div class="reaction-detail-title">Dettaglio reaction</div><div class="reaction-detail-list" data-reaction-detail-list>Nessuna reaction salvata.</div>';
        root.append(detailPopover);
        detailList = detailPopover.querySelector('[data-reaction-detail-list]');
      }

      const renderDetails = () => {
        if (!(detailList instanceof HTMLElement)) return;
        const entries = Array.isArray(serverFeedback?.reactionEntries)
          ? serverFeedback.reactionEntries
          : (Array.isArray(data.reactionEntries) ? data.reactionEntries : []);
        const validEntries = entries.filter((item) => reactionKeys.includes(String(item?.value || item?.reaction || '')));
        if (!validEntries.length) {
          detailList.textContent = 'Nessuna reaction salvata.';
          return;
        }
        detailList.replaceChildren(...validEntries.map((item) => {
          const row = document.createElement('div');
          const value = String(item.value || item.reaction || '');
          row.textContent = `${reactionLabels[value] || value} ${item.userName || item.user_name || 'Utente'}`;
          return row;
        }));
      };

      detailButton?.addEventListener('click', () => {
        if (!(detailPopover instanceof HTMLElement)) return;
        renderDetails();
        detailPopover.hidden = !detailPopover.hidden;
      });

      // countsStore è sempre la fonte di verità per la visualizzazione
      const getDisplayCounts = () => {
        const store = readObject(reactionCountKey);
        return normalizeCounts(store[data.id] || initialCounts);
      };

      const render = () => {
        const counts = getDisplayCounts();
        const choices = readObject(reactionChoiceKey);
        const choiceId = reactionChoiceId(data.id);
        reactionKeys.forEach((key) => {
          const countEl = root.querySelector(`[data-count="${key}"]`);
          const btn = root.querySelector(`[data-reaction="${key}"]`);
          if (countEl instanceof HTMLElement) countEl.textContent = String(counts[key]);
          if (btn instanceof HTMLElement) btn.classList.toggle('is-active', choices[choiceId] === key);
        });
      };

      // Sincronizza i conteggi dal server e aggiorna lo store locale
      const refreshServerReactions = async () => {
        const feedback = await fetchFeedback(data.id);
        serverFeedback = feedback || serverFeedback;
        if (feedback?.reactions) {
          const store = readObject(reactionCountKey);
          store[data.id] = normalizeCounts(feedback.reactions);
          writeObject(reactionCountKey, store);
          render();
        }
        const identity = currentIdentity();
        const choiceId = reactionChoiceId(data.id, identity);
        const savedReaction = currentUserReaction(feedback, identity);
        const choices = readObject(reactionChoiceKey);
        if (savedReaction) {
          choices[choiceId] = savedReaction;
        } else {
          delete choices[choiceId];
        }
        writeObject(reactionChoiceKey, choices);
        renderDetails();
        render();
      };

      root.querySelectorAll('[data-reaction]').forEach((button) => {
        button.addEventListener('click', async () => {
          const next = button.getAttribute('data-reaction');
          if (!reactionKeys.includes(next)) return;
          if (window.__DDGPILLI?.hasIdentity && !window.__DDGPILLI.hasIdentity()) {
            window.__DDGPILLI.showIdentityModal?.();
            return;
          }

          const store = readObject(reactionCountKey);
          const choices = readObject(reactionChoiceKey);
          const identity = currentIdentity();
          const choiceId = reactionChoiceId(data.id, identity);
          const previousCounts = normalizeCounts(store[data.id] || initialCounts);
          const counts = normalizeCounts(previousCounts);
          const previous = choices[choiceId];

          const isToggleOff = previous === next;

          if (isToggleOff) {
            counts[next] = Math.max(0, counts[next] - 1);
            delete choices[choiceId];
          } else {
            if (reactionKeys.includes(previous)) {
              counts[previous] = Math.max(0, counts[previous] - 1);
            }
            counts[next] += 1;
            choices[choiceId] = next;
          }

          // Aggiornamento ottimistico immediato
          store[data.id] = counts;
          writeObject(reactionCountKey, store);
          writeObject(reactionChoiceKey, choices);
          render();
          if (button instanceof HTMLButtonElement) button.disabled = true;

          try {
            const apiResult = await postFeedback('/save_reaction', {
              id: data.id,
              reaction: isToggleOff ? null : next,
              previousReaction: previous || null,
              userId: identity.userId || '',
              userKey: identityUserKey(identity),
              userName: displayName(identity),
              nome: identity.nome || '',
              cognome: identity.cognome || '',
            });
            // Se l'API restituisce i conteggi aggiornati, sovrascriviamo lo store
            const savedReactions = feedbackReactions(apiResult);
            if (savedReactions) {
              const latestStore = readObject(reactionCountKey);
              latestStore[data.id] = normalizeCounts(savedReactions);
              writeObject(reactionCountKey, latestStore);
            }
            serverFeedback = apiResult?.feedback || apiResult || serverFeedback;
            renderDetails();
          } catch (error) {
            console.warn('Salvataggio reaction fallito, rollback locale.', error);
            // In caso di errore: ripristino conteggi e scelta precedente
            const latestStore = readObject(reactionCountKey);
            latestStore[data.id] = previousCounts;
            writeObject(reactionCountKey, latestStore);
            const latestChoices = readObject(reactionChoiceKey);
            if (previous) {
              latestChoices[choiceId] = previous;
            } else {
              delete latestChoices[choiceId];
            }
            writeObject(reactionChoiceKey, latestChoices);
          } finally {
            if (button instanceof HTMLButtonElement) button.disabled = false;
            render();
          }
        });
      });

      refreshServerReactions();
      render();
    });
  }

  function initDedicationPlus() {
    initPlusVotes();
    initReactions();
  }

  initDedicationPlus();
  document.addEventListener('astro:page-load', initDedicationPlus);
</script>

