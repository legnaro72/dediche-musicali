---
// src/components/DedicationImage.astro
// Componente immagine con landscape-pan automatico (runtime JS detection).
export interface Props {
  src: string;
  alt?: string;
  width?: number;
  height?: number;
  class?: string;
  style?: string;
  loading?: 'lazy' | 'eager';
  wrapClass?: string;
  wrapStyle?: string;
}

const {
  src,
  alt = '',
  width = 480,
  height = 600,
  class: className = '',
  style = '',
  loading = 'lazy',
  wrapClass = '',
  wrapStyle = '',
} = Astro.props;
---

<div class={`landscape-pan-wrap ${wrapClass}`} style={wrapStyle}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={`ded-image ${className}`}
    style={`width:100%;height:100%;object-fit:cover;${style}`}
    loading={loading}
    data-landscape-check
  />
</div>

<script>
  // Rileva landscape al caricamento → applica pan cinematico
  function initLandscapePan() {
    document.querySelectorAll('img[data-landscape-check]').forEach(function(el) {
      var img = /** @type {HTMLImageElement} */ (el);
      function check() {
        // Landscape se larghezza > altezza * 1.15 (threshold 15%)
        if (img.naturalWidth > img.naturalHeight * 1.15) {
          img.classList.add('landscape-pan');
        }
      }
      if (img.complete && img.naturalWidth > 0) {
        check();
      } else {
        img.addEventListener('load', check, { once: true });
      }
    });
  }
  initLandscapePan();
</script>
