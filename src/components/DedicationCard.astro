---
// src/components/DedicationCard.astro
import DedicationImage from './DedicationImage.astro';
export interface Props {
  id: string;
  date: string;
  day_name?: string;
  song_title: string;
  artist: string;
  image?: { path?: string; alt?: string };
  tags?: string[];
  dedication_text?: string;
  short_phrase?: string;
  class?: string;
}

const {
  id,
  date,
  day_name,
  song_title,
  artist,
  image,
  tags,
  dedication_text = '',
  short_phrase = '',
  class: className = '',
} = Astro.props;

const base = (import.meta.env.BASE_URL ?? '/').replace(/([^/])$/, '$1/');
const href = `${base}dediche/${id}/`;
const imgSrc = image?.path ? base + image.path.replace(/^\//, '') : null;
const imgAlt = image?.alt ?? `Dedica: ${song_title} di ${artist}`;

// Format date
const [year, month, day] = date.split('-');
const months = ['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic'];
const dateLabel = `${parseInt(day)} ${months[parseInt(month)-1]} ${year}`;
const searchText = [
  song_title,
  artist,
  dedication_text,
  short_phrase,
  ...(tags ?? []),
].join(' ');
const monthValue = date.substring(0, 7);
---

<a
  href={href}
  class={`dedication-card ${className}`}
  data-artist={artist}
  data-month={monthValue}
  data-search={searchText}
>
  <div class="dedication-card-img-wrap">
    {imgSrc ? (
      <DedicationImage
        src={imgSrc}
        alt={imgAlt}
        width={540}
        height={675}
        wrapClass="dedication-card-img"
        wrapStyle="aspect-ratio:4/5;"
      />
    ) : (
      <div class="dedication-card-img" style="background:linear-gradient(135deg,rgba(124,58,237,0.3),rgba(236,72,153,0.15)); display:flex; align-items:center; justify-content:center; font-size:3rem;">
        &#9834;
      </div>
    )}
  </div>
  <div class="dedication-card-body">
    <div class="dedication-card-date">
      {day_name ? `${day_name} - ` : ''}{dateLabel}
    </div>
    <div class="dedication-card-song">{song_title}</div>
    <div class="dedication-card-artist">{artist}</div>
    {short_phrase && (
      <p class="dedication-card-phrase">{short_phrase}</p>
    )}
    {tags && tags.length > 0 && (
      <div style="margin-top:0.75rem; display:flex; flex-wrap:wrap; gap:0.4rem;">
        {tags.slice(0, 3).map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
