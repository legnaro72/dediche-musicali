---
// src/components/UserIdentityModal.astro
// Modal "una tantum" per raccogliere nome e cognome dell'utente.
// I dati vengono salvati solo in localStorage sul dispositivo.
---

<div class="uid-modal" id="uid-modal" data-uid-modal hidden aria-modal="true" role="dialog" aria-labelledby="uid-modal-title">
  <div class="uid-modal-backdrop" data-uid-backdrop></div>
  <div class="uid-modal-dialog">
    <div class="uid-modal-header">
      <span class="uid-modal-kicker">♪ DDGPilli</span>
      <h2 id="uid-modal-title" class="uid-modal-title">Benvenuto/a!</h2>
      <p class="uid-modal-subtitle">
        Inserisci il tuo nome per partecipare con reactions e commenti.
      </p>
    </div>

    <form class="uid-modal-form" id="uid-form" data-uid-form novalidate>
      <div class="uid-field-group">
        <label class="uid-label" for="uid-nome">Nome</label>
        <input
          class="uid-input"
          id="uid-nome"
          name="nome"
          type="text"
          autocomplete="given-name"
          placeholder="Il tuo nome"
          required
          maxlength="50"
        />
      </div>

      <div class="uid-field-group">
        <label class="uid-label" for="uid-cognome">Cognome</label>
        <input
          class="uid-input"
          id="uid-cognome"
          name="cognome"
          type="text"
          autocomplete="family-name"
          placeholder="Il tuo cognome"
          required
          maxlength="50"
        />
      </div>

      <p class="uid-privacy-note" aria-label="Nota sulla privacy">
        🔒 Il tuo nome è salvato <strong>solo su questo dispositivo</strong> (localStorage).
        Verrà usato per reactions, voti e conteggio accessi inviati al sistema. Non viene creato nessun account.
      </p>

      <div class="uid-actions">
        <button type="submit" class="btn btn-primary uid-submit-btn" id="uid-submit">
          Continua →
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Trigger "Modifica profilo" — invisibile di default, attivabile da navbar/footer -->
<button class="uid-edit-trigger" id="uid-edit-trigger" data-uid-edit type="button" hidden aria-label="Modifica nome e cognome">
  ✏️
</button>

<style>
  .uid-modal {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
  }

  .uid-modal[hidden] {
    display: none !important;
  }

  .uid-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(12px);
  }

  .uid-modal-dialog {
    position: relative;
    z-index: 1;
    width: min(100%, 420px);
    padding: clamp(1.5rem, 5vw, 2.5rem);
    background: linear-gradient(145deg, #071221 0%, #09192a 100%);
    border: 1px solid rgba(0, 87, 200, 0.34);
    border-radius: 24px;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.6),
      0 0 60px rgba(0, 87, 200, 0.14);
    animation: uid-slide-up 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes uid-slide-up {
    from { opacity: 0; transform: translateY(32px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .uid-modal-header {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .uid-modal-kicker {
    display: block;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: linear-gradient(135deg, #ff0033, #0057c8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.6rem;
  }

  .uid-modal-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.6rem, 5vw, 2rem);
    font-weight: 700;
    color: #f7fbff;
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }

  .uid-modal-subtitle {
    color: rgba(247, 251, 255, 0.68);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .uid-modal-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .uid-field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .uid-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(247, 251, 255, 0.74);
  }

  .uid-input {
    width: 100%;
    padding: 0.85rem 1.1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(0, 87, 200, 0.32);
    border-radius: 14px;
    color: #f7fbff;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    outline: none;
    transition: all 0.2s ease;
  }

  .uid-input::placeholder {
    color: rgba(247, 251, 255, 0.34);
  }

  .uid-input:focus {
    border-color: #ff0033;
    box-shadow: 0 0 0 3px rgba(255, 0, 51, 0.16);
    background: rgba(255, 255, 255, 0.07);
  }

  .uid-input.uid-error {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15);
  }

  .uid-privacy-note {
    font-size: 0.78rem;
    color: rgba(247, 251, 255, 0.5);
    line-height: 1.5;
    padding: 0.7rem 0.9rem;
    background: rgba(0, 87, 200, 0.08);
    border: 1px solid rgba(0, 87, 200, 0.2);
    border-radius: 10px;
    margin-top: 0.25rem;
  }

  .uid-privacy-note strong {
    color: rgba(247, 251, 255, 0.74);
  }

  .uid-actions {
    margin-top: 0.5rem;
  }

  .uid-submit-btn {
    width: 100%;
    justify-content: center;
    font-size: 1rem;
    padding: 0.9rem 1.5rem;
  }

  /* Edit trigger button — usato nella navbar */
  .uid-edit-trigger {
    position: relative;
    z-index: 145;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    min-height: 44px;
    padding: 0.65rem 0.95rem;
    border: 1px solid rgba(0, 87, 200, 0.5);
    border-radius: 9999px;
    background: rgba(0, 87, 200, 0.14);
    color: #f7fbff;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: all 0.2s ease;
    pointer-events: auto;
    white-space: nowrap;
    box-shadow: 0 6px 18px rgba(0, 87, 200, 0.18);
  }

  .uid-edit-trigger:hover {
    background: rgba(0, 87, 200, 0.22);
    color: #f7fbff;
    border-color: rgba(0, 87, 200, 0.72);
    transform: translateY(-2px);
  }

  .uid-edit-trigger[hidden] {
    display: none !important;
  }
</style>

<script>
  const UID_NOME_KEY    = 'ddgpilli-user-nome';
  const UID_COGNOME_KEY = 'ddgpilli-user-cognome';
  const UID_USER_ID_KEY = 'ddgpilli-user-id';
  const UID_PROFILE_IDS_KEY = 'ddgpilli-profile-user-ids';

  function readProfileIds() {
    try {
      const value = JSON.parse(localStorage.getItem(UID_PROFILE_IDS_KEY) || '{}');
      return value && typeof value === 'object' ? value : {};
    } catch {
      return {};
    }
  }

  function profileKey(nome, cognome) {
    return [nome, cognome]
      .map((part) => String(part || '').trim().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''))
      .filter(Boolean)
      .join('|');
  }

  function createUserId() {
    return window.crypto?.randomUUID?.() || `local-${Date.now()}-${Math.random().toString(36).slice(2)}`;
  }

  function getOrCreateUserId(nome = '', cognome = '') {
    const key = profileKey(nome, cognome);
    if (!key) {
      let fallbackId = localStorage.getItem(UID_USER_ID_KEY) || '';
      if (!fallbackId) {
        fallbackId = createUserId();
        localStorage.setItem(UID_USER_ID_KEY, fallbackId);
      }
      return fallbackId;
    }
    const ids = readProfileIds();
    let userId = ids[key] || '';
    if (!userId) {
      userId = createUserId();
      ids[key] = userId;
      localStorage.setItem(UID_PROFILE_IDS_KEY, JSON.stringify(ids));
    }
    localStorage.setItem(UID_USER_ID_KEY, userId);
    return userId;
  }

  function getUserIdentity() {
    const nome = localStorage.getItem(UID_NOME_KEY) || '';
    const cognome = localStorage.getItem(UID_COGNOME_KEY) || '';
    return {
      userId: getOrCreateUserId(nome, cognome),
      nome,
      cognome,
      displayName: [nome, cognome].filter(Boolean).join(' ').trim() || 'Utente',
    };
  }

  function saveUserIdentity(nome, cognome) {
    const cleanNome = nome.trim();
    const cleanCognome = cognome.trim();
    const userId = getOrCreateUserId(cleanNome, cleanCognome);
    localStorage.setItem(UID_NOME_KEY, cleanNome);
    localStorage.setItem(UID_COGNOME_KEY, cleanCognome);
    localStorage.setItem(UID_USER_ID_KEY, userId);
    window.dispatchEvent(new CustomEvent('ddgpilli:identity-saved', {
      detail: { userId, nome: cleanNome, cognome: cleanCognome },
    }));
  }

  function hasIdentity() {
    const { nome, cognome } = getUserIdentity();
    return nome.length > 0 && cognome.length > 0;
  }

  function showModal(prefill = false) {
    const modal = document.querySelector('[data-uid-modal]');
    if (!(modal instanceof HTMLElement)) return;

    if (prefill) {
      const { nome, cognome } = getUserIdentity();
      const nomeInput    = document.getElementById('uid-nome');
      const cognomeInput = document.getElementById('uid-cognome');
      if (nomeInput instanceof HTMLInputElement)    nomeInput.value    = nome;
      if (cognomeInput instanceof HTMLInputElement) cognomeInput.value = cognome;
    }

    modal.hidden = false;
    document.body.classList.add('uid-modal-open');

    // Focus sul primo campo vuoto
    const nomeInput = document.getElementById('uid-nome');
    if (nomeInput instanceof HTMLInputElement && !nomeInput.value) {
      nomeInput.focus();
    } else {
      const cognomeInput = document.getElementById('uid-cognome');
      if (cognomeInput instanceof HTMLInputElement) cognomeInput.focus();
    }
  }

  function hideModal() {
    const modal = document.querySelector('[data-uid-modal]');
    if (modal instanceof HTMLElement) modal.hidden = true;
    document.body.classList.remove('uid-modal-open');
  }

  function updateEditTrigger() {
    const btns = document.querySelectorAll('[data-uid-edit]');
    btns.forEach((btn) => {
      if (btn instanceof HTMLElement) {
        btn.hidden = !hasIdentity();
      }
    });
  }

  function initUserIdentityModal() {
    const modal       = document.querySelector('[data-uid-modal]');
    const form        = document.getElementById('uid-form');
    const backdrop    = document.querySelector('[data-uid-backdrop]');
    if (!modal || !form) return;

    // Mostra se non ha ancora il nome
    if (!hasIdentity()) {
      // Piccolo delay per permettere al sito di caricarsi visivamente
      setTimeout(() => showModal(false), 600);
    }

    updateEditTrigger();

    // Salva al submit
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const nomeInput    = document.getElementById('uid-nome');
      const cognomeInput = document.getElementById('uid-cognome');

      let valid = true;

      if (!(nomeInput instanceof HTMLInputElement) || !nomeInput.value.trim()) {
        nomeInput?.classList.add('uid-error');
        nomeInput?.focus();
        valid = false;
      } else {
        nomeInput.classList.remove('uid-error');
      }

      if (!(cognomeInput instanceof HTMLInputElement) || !cognomeInput.value.trim()) {
        cognomeInput?.classList.add('uid-error');
        if (valid) cognomeInput?.focus();
        valid = false;
      } else {
        cognomeInput.classList.remove('uid-error');
      }

      if (!valid) return;

      saveUserIdentity(nomeInput.value, cognomeInput.value);
      updateEditTrigger();
      hideModal();
    });

    // Chiudi cliccando sul backdrop
    backdrop?.addEventListener('click', () => {
      // Chiude solo se l'utente ha già un'identità salvata
      if (hasIdentity()) hideModal();
    });

    if (!window.__DDGPILLI_IDENTITY_EDIT_BOUND) {
      window.__DDGPILLI_IDENTITY_EDIT_BOUND = true;
      document.addEventListener('click', (e) => {
        const trigger = e.target instanceof Element ? e.target.closest('[data-uid-edit]') : null;
        if (!trigger) return;
        e.preventDefault();
        showModal(true);
      });
    }
  }

  // Esporta per uso esterno (DedicationPlus, etc.)
  window.__DDGPILLI = window.__DDGPILLI || {};
  window.__DDGPILLI.getUserIdentity = () => {
    const nome = localStorage.getItem('ddgpilli-user-nome') || '';
    const cognome = localStorage.getItem('ddgpilli-user-cognome') || '';
    return {
      userId: getOrCreateUserId(nome, cognome),
      nome,
      cognome,
      displayName: [nome, cognome].filter(Boolean).join(' ').trim() || 'Utente',
    };
  };
  window.__DDGPILLI.hasIdentity = () => {
    const { nome, cognome } = window.__DDGPILLI.getUserIdentity();
    return nome.length > 0 && cognome.length > 0;
  };
  window.__DDGPILLI.showIdentityModal = () => showModal(true);

  initUserIdentityModal();
  document.addEventListener('astro:page-load', initUserIdentityModal);
</script>

